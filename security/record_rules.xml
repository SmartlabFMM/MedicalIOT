<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="rule_patient_assigned_only" model="ir.rule">
        <field name="name">Patients: Assigned only</field>
        <field name="model_id" ref="model_med_patient"/>
        <field name="groups" eval="[(4, ref('med_iot_command_center.group_med_senior_doctor')), (4, ref('med_iot_command_center.group_med_junior_staff'))]"/>
        <field name="domain_force">['|', ('assigned_doctor_id', '=', user.id), ('assigned_doctor_id', '=', False)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_alert_patient_assigned_only" model="ir.rule">
        <field name="name">Alerts: follow patient visibility</field>
        <field name="model_id" ref="model_med_alert"/>
        <field name="groups" eval="[(4, ref('med_iot_command_center.group_med_senior_doctor')), (4, ref('med_iot_command_center.group_med_junior_staff'))]"/>
        <field name="domain_force">['|', ('patient_id.assigned_doctor_id', '=', user.id), ('create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_reading_patient_assigned_only" model="ir.rule">
        <field name="name">Readings: follow patient visibility</field>
        <field name="model_id" ref="model_med_vital_reading"/>
        <field name="groups" eval="[(4, ref('med_iot_command_center.group_med_senior_doctor')), (4, ref('med_iot_command_center.group_med_junior_staff'))]"/>
        <field name="domain_force">['|', ('patient_id.assigned_doctor_id', '=', user.id), ('patient_id.assigned_doctor_id', '=', False)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>


    <record id="rule_med_patient_admin_all" model="ir.rule">
        <field name="name">Patients: Admin all</field>
        <field name="model_id" ref="model_med_patient"/>
        <field name="groups" eval="[(4, ref('med_iot_command_center.group_med_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
</odoo>