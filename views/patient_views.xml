<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- KANBAN VIEW -->
<record id="view_med_patient_kanban" model="ir.ui.view">
    <field name="name">med.patient.kanban</field>
    <field name="model">med.patient</field>
    <field name="arch" type="xml">
        <kanban records_draggable="0" class="mediot_patient_kanban_force">
            <field name="id"/>
            <field name="name"/>
            <field name="ref"/>
            <field name="room"/>
            <field name="status"/>
            <field name="latest_spo2"/>
            <field name="latest_ecg_bpm"/>
            <field name="latest_temp"/>
            <field name="image_128"/>
            <field name="write_date"/>
            <field name="pending_alert_count"/>
            <field name="age"/>
            <field name="gender"/>
            <field name="smoker"/>
            <field name="sporty"/>

            <templates>
                <t t-name="card">
                    <div class="mediot_patient_card_force">
                        <div class="mediot_patient_real_photo_shell">
                            <img t-att-src="'/mediot/patient_photo/' + record.id.raw_value + '?unique=' + record.write_date.raw_value"
                                 class="mediot_patient_real_photo_img"
                                 alt="Patient Photo"/>

                            <t t-if="record.pending_alert_count.raw_value &gt; 0">
                                <div class="mediot_patient_alert_force">
                                    <t t-esc="record.pending_alert_count.raw_value"/>
                                </div>
                            </t>
                        </div>
                        <div class="mediot_patient_body_force">
                            <div class="mediot_patient_top_force">
                                <div>
                                    <div class="mediot_patient_name_force">
                                        <t t-esc="record.name.value"/>
                                    </div>
                                    <div class="mediot_patient_meta_force">
                                        <t t-esc="record.gender.value"/> · Age <t t-esc="record.age.raw_value or '—'"/>
                                    </div>
                                </div>

                                <span t-att-class="'mediot_patient_status_force ' + (record.status.raw_value or 'stable')">
                                    <t t-esc="record.status.value"/>
                                </span>
                            </div>

                            <div class="mediot_patient_line_force">
                                <i class="fa fa-id-card-o"/>
                                <t t-esc="record.ref.value"/>
                            </div>

                            <div class="mediot_patient_line_force">
                                <i class="fa fa-bed"/>
                                <t t-esc="record.room.value or '—'"/>
                            </div>

                            <div class="mediot_patient_divider_force"/>

                            <div class="mediot_patient_vitals_force">
                                <div>
                                    <strong><t t-esc="record.latest_spo2.raw_value or '—'"/><t t-if="record.latest_spo2.raw_value">%</t></strong>
                                    <span>SpO2</span>
                                </div>
                                <div>
                                    <strong><t t-esc="record.latest_ecg_bpm.raw_value or '—'"/><t t-if="record.latest_ecg_bpm.raw_value"><small>bpm</small></t></strong>
                                    <span>HR</span>
                                </div>
                                <div>
                                    <strong><t t-esc="record.latest_temp.raw_value or '—'"/><t t-if="record.latest_temp.raw_value">°C</t></strong>
                                    <span>Temp</span>
                                </div>
                            </div>

                            <div class="mediot_patient_bottom_force">
                                <span class="mediot_patient_green_dot_force"></span>
                                <button name="action_print_medical_report"
                                        type="object"
                                        class="btn btn-primary mediot_patient_download_force">
                                    <i class="fa fa-download"/> Download
                                </button>
                            </div>
                        </div>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>


<!-- LIST VIEW -->
<record id="view_med_patient_tree" model="ir.ui.view">
    <field name="name">med.patient.tree</field>
    <field name="model">med.patient</field>
    <field name="arch" type="xml">
        <list decoration-danger="status=='critical'" decoration-warning="status=='warning'">
            <field name="ref"/>
            <field name="name"/>
            <field name="age"/>
            <field name="room"/>
            <field name="smoker"/>
            <field name="sporty"/>
            <field name="status" widget="badge"
                   decoration-danger="status == 'critical'"
                   decoration-warning="status == 'warning'"
                   decoration-success="status == 'stable'"/>
            <field name="latest_temp"/>
            <field name="latest_spo2"/>
            <field name="latest_ecg_bpm"/>
            <field name="assigned_doctor_id"/>
            <field name="pending_alert_count"/>
            <button name="action_print_medical_report" type="object" icon="fa-download" title="Download Medical Report"/>
        </list>
    </field>
</record>


<!-- FORM VIEW -->
<record id="view_med_patient_form" model="ir.ui.view">
    <field name="name">med.patient.form</field>
    <field name="model">med.patient</field>
    <field name="arch" type="xml">
        <form class="mediot-patient-fullscreen o_mediot_patient_detail_dashboard">
            <header>
            </header>
            <sheet class="o_mediot_patient_detail_sheet">
                <!-- TOP STATUS BAR -->
                <div style="background:#1e2d3d;border-radius:10px;padding:12px 20px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;">
                    <div style="display:flex;align-items:center;gap:12px;">
                        <field name="status" widget="badge" nolabel="1"
                               decoration-danger="status=='critical'"
                               decoration-warning="status=='warning'"
                               decoration-success="status=='stable'"/>
                        <span style="font-size:.82rem;color:rgba(255,255,255,.5);">
                            Patient ID:
                            <field name="ref" nolabel="1" readonly="1"
                                   style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;color:rgba(255,255,255,.85);font-weight:600;"/>
                        </span>
                    </div>
                    <span style="font-size:.78rem;color:rgba(255,255,255,.45);">
                        <button name="action_print_medical_report" type="object" string="Download Report" icon="fa-download" class="btn-info"/>
                        <field name="latest_reading_at" nolabel="1" readonly="1" widget="datetime"
                               style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;color:rgba(255,255,255,.7);"/>
                    </span>
                </div>

                <!-- MAIN LAYOUT: LEFT PANEL + RIGHT CONTENT -->
                <div style="display:grid;grid-template-columns:220px 1fr;gap:20px;align-items:start;">

                    <!-- LEFT PANEL -->
                    <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:24px 18px;text-align:center;">
                        <div style="margin-bottom:16px;display:flex;justify-content:center;">
                            <field name="image_128" widget="image" class="oe_avatar"
                                   options="{'size':[96,96],'preview_image':'image_128'}"
                                   style="width:96px;height:96px;border-radius:16px;object-fit:cover;border:2px solid #e2e8f0;"/>
                        </div>
                        <field name="name" nolabel="1"
                               style="font-size:1.05rem;font-weight:700;color:#1e293b;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:7px;padding:6px 10px;text-align:center;width:100%;display:block;margin-bottom:8px;"
                               placeholder="Patient Name"/>
                        <div style="font-size:.82rem;color:#64748b;margin-bottom:16px;display:flex;align-items:center;justify-content:center;gap:6px;">
                            <span>Age:</span>
                            <field name="age" nolabel="1"
                                   style="display:inline;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:6px;padding:3px 8px;font-size:.88rem;color:#1e293b;font-weight:600;width:50px;text-align:center;"/>
                        </div>
                        <div style="border-top:1px solid #f1f5f9;margin-bottom:16px;"/>
                        <div style="text-align:left;">
                            <div style="margin-bottom:12px;">
                                <div style="font-size:.62rem;text-transform:uppercase;letter-spacing:.1em;color:#94a3b8;margin-bottom:4px;font-weight:600;">Gender</div>
                                <field name="gender" nolabel="1"
                                       style="font-size:.88rem;color:#1e293b;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:7px;padding:6px 8px;width:100%;"/>
                            </div>
                            <div style="margin-bottom:12px;">
                                <div style="font-size:.62rem;text-transform:uppercase;letter-spacing:.1em;color:#94a3b8;margin-bottom:4px;font-weight:600;">Room / Bed</div>
                                <field name="room" nolabel="1" placeholder="e.g. ICU-01"
                                       style="font-size:.88rem;color:#1e293b;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:7px;padding:6px 8px;width:100%;"/>
                            </div>
                            <div style="margin-bottom:12px;">
                                <div style="font-size:.62rem;text-transform:uppercase;letter-spacing:.1em;color:#94a3b8;margin-bottom:4px;font-weight:600;">Department</div>
                                <field name="department" nolabel="1" placeholder="—"
                                       style="font-size:.88rem;color:#1e293b;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:7px;padding:6px 8px;width:100%;"/>
                            </div>
                            <div style="margin-bottom:12px;">
                                <div style="font-size:.62rem;text-transform:uppercase;letter-spacing:.1em;color:#94a3b8;margin-bottom:4px;font-weight:600;">Assigned Doctor</div>
                                <field name="assigned_doctor_id" nolabel="1"
                                       options="{'no_create':True}"/>
                            </div>
                            <div style="padding:10px;background:#f8fafc;border-radius:8px;border:1px solid #f1f5f9;display:flex;align-items:center;justify-content:space-between;">
                                <span style="font-size:.82rem;color:#475569;font-weight:500;">Active Patient</span>
                                <field name="active" nolabel="1"/>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT CONTENT -->
                    <div>

                        
                        <!-- OLD_TOP_VITAL_CARDS_REMOVED_SAFE -->
                        
<!-- PATIENT_PROFILE_VITAL_CURVES_SAFE_START -->
                        <div class="mediot_vital_curves_wrapper">
                            <field name="vitals_curves_html" widget="html" nolabel="1" readonly="1"/>
                        </div>
                        <!-- PATIENT_PROFILE_VITAL_CURVES_SAFE_END -->

                        <!-- CVD AI RESULT moved to Data History Predict popup -->


                        
                        <!-- ALERTS -->
                        <div class="mediot_alerts_html_card">
                            <div class="mediot_alerts_html_header">
                                <div class="mediot_alerts_html_title">Alerts</div>
                                <field name="pending_alert_count" nolabel="1" readonly="1"
                                       class="mediot_alerts_pending_count"/>
                            </div>
                            <field name="patient_alerts_table_html" widget="html" nolabel="1" readonly="1"/>
                        </div>


                    </div><!-- /right -->
                </div><!-- /grid -->
            </sheet>
            <chatter/>
        </form>
    </field>
</record>


<!-- SEARCH VIEW -->
<record id="view_med_patient_search" model="ir.ui.view">
    <field name="name">med.patient.search</field>
    <field name="model">med.patient</field>
    <field name="arch" type="xml">
        <search>
            <field name="name"/>
            <field name="ref"/>
            <field name="room"/>
            <field name="assigned_doctor_id"/>
            <filter string="Critical" name="critical" domain="[('status','=','critical')]"/>
            <filter string="Warning"  name="warning"  domain="[('status','=','warning')]"/>
            <filter string="Stable"   name="stable"   domain="[('status','=','stable')]"/>
            <filter string="Smoker"   name="smoker"   domain="[('smoker','=',True)]"/>
            <filter string="Sporty"   name="sporty"   domain="[('sporty','=',True)]"/>
            <filter string="Age 60+"  name="elderly"  domain="[('age','&gt;=',60)]"/>
        </search>
    </field>
</record>


<!-- ACTION -->
<record id="action_med_patient" model="ir.actions.act_window">
    <field name="name">Patients</field>
    <field name="res_model">med.patient</field>
    <field name="view_mode">kanban,list,form</field>
    <field name="search_view_id" ref="view_med_patient_search"/>
</record>
    <!-- CVD_PREDICT_POPUP_FROM_HISTORY_START -->
    <record id="view_med_patient_cvd_predict_popup" model="ir.ui.view">
        <field name="priority">1000</field>
        <field name="name">med.patient.cvd.predict.popup.form</field>
        <field name="model">med.patient</field>
        <field name="arch" type="xml">
<form string="CVD AI Prediction">
    <sheet>
        <div style="background:#f8fafc;border:1px solid #d7dee8;border-radius:18px;padding:22px 26px;box-shadow:0 12px 28px rgba(15,23,42,.06);">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px;">
                <div>
                    <div style="font-size:1.25rem;font-weight:950;color:#0f172a;">CVD AI Prediction</div>
                    <div style="font-size:.9rem;color:#64748b;margin-top:5px;">FastAPI Random Forest cardiovascular risk analysis</div>
                </div>
                <button name="action_compute_cvd_risk"
                        type="object"
                        string="Compute Risk"
                        icon="fa-heartbeat"
                        class="btn-primary"
                        style="background:#155e63;border-color:#155e63;border-radius:999px;padding:9px 18px;font-weight:900;"/>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:stretch;">
                <div style="background:#ffffff;border:1px solid #dbe3ec;border-radius:14px;overflow:hidden;">
                    <div style="background:#e5e7eb;color:#111827;font-weight:950;padding:13px 18px;border-bottom:1px solid #d1d5db;">
                        Clinical Input Data
                    </div>

                    <div style="padding:16px 20px;display:grid;grid-template-columns:1fr 1fr;row-gap:15px;column-gap:20px;">
                        <div style="font-weight:850;color:#111827;">Height (cm)</div>
                        <div><field name="cvd_height" nolabel="1"/></div>

                        <div style="font-weight:850;color:#111827;">Weight (kg)</div>
                        <div><field name="cvd_weight" nolabel="1"/></div>

                        <div style="font-weight:850;color:#111827;">Systolic BP</div>
                        <div><field name="cvd_ap_hi" nolabel="1"/></div>

                        <div style="font-weight:850;color:#111827;">Diastolic BP</div>
                        <div><field name="cvd_ap_lo" nolabel="1"/></div>

                        <div style="font-weight:850;color:#111827;">Cholesterol</div>
                        <div><field name="cvd_cholesterol" nolabel="1"/></div>

                        <div style="font-weight:850;color:#111827;">Glucose</div>
                        <div><field name="cvd_gluc" nolabel="1"/></div>

                        <div style="font-weight:850;color:#111827;">Alcohol Intake</div>
                        <div><field name="cvd_alco" nolabel="1"/></div>

                        <div style="font-weight:850;color:#111827;">Physically Active</div>
                        <div><field name="cvd_active" nolabel="1"/></div>
                    </div>
                </div>

                <div style="background:#ffffff;border:1px solid #dbe3ec;border-radius:14px;overflow:hidden;">
                    <div style="background:#e5e7eb;color:#111827;font-weight:950;padding:13px 18px;border-bottom:1px solid #d1d5db;">
                        Prediction Result
                    </div>

                    <div style="padding:16px 20px;">
                        <div style="display:grid;grid-template-columns:145px 1fr 110px 90px;gap:12px;align-items:center;margin-bottom:12px;">
                            <div style="font-weight:900;color:#7f1d1d;">CVD Risk</div>
                            <div>
                                <field name="cvd_risk" nolabel="1" readonly="1" widget="badge"
                                       decoration-success="cvd_risk == 'low'"
                                       decoration-warning="cvd_risk == 'medium'"
                                       decoration-danger="cvd_risk in ('high', 'critical')"/>
                            </div>
                            <div style="font-weight:900;color:#7f1d1d;">CVD Alert</div>
                            <div><field name="cvd_alert" nolabel="1" readonly="1" widget="boolean_toggle"/></div>
                        </div>

                        <div style="display:grid;grid-template-columns:145px 1fr;gap:12px;margin-bottom:10px;">
                            <div style="font-weight:900;color:#7f1d1d;">Probability</div>
                            <div><field name="cvd_probability" nolabel="1" readonly="1"/></div>
                        </div>

                        <div style="display:grid;grid-template-columns:145px 1fr;gap:12px;margin-bottom:10px;">
                            <div style="font-weight:900;color:#7f1d1d;">CVD AI Message</div>
                            <div style="line-height:1.3;"><field name="cvd_message" nolabel="1" readonly="1"/></div>
                        </div>

                        <div style="display:grid;grid-template-columns:145px 1fr;gap:12px;margin-bottom:14px;">
                            <div style="font-weight:900;color:#7f1d1d;">Last checked</div>
                            <div><field name="cvd_last_checked" nolabel="1" readonly="1"/></div>
                        </div>

                        <div invisible="not cvd_last_checked" style="border-top:1px solid #cbd5e1;padding-top:12px;">
                            <div style="font-weight:950;color:#111827;margin-bottom:10px;">
                                INFLUENCE DES PARAMÈTRES <span style="font-weight:700;color:#475569;">(Feature Importance)</span>
                            </div>

                            <div style="display:grid;grid-template-columns:120px 1fr;gap:8px 12px;align-items:center;font-size:.86rem;">
                                <div style="text-align:right;color:#334155;font-weight:800;">Systolic BP</div>
                                <div style="background:#e5e7eb;border-radius:7px;height:25px;overflow:hidden;">
                                    <div style="width:88%;height:100%;background:#a3423f;color:white;text-align:right;padding-right:8px;font-weight:900;line-height:25px;">+12.1</div>
                                </div>

                                <div style="text-align:right;color:#334155;font-weight:800;">Diastolic BP</div>
                                <div style="background:#e5e7eb;border-radius:7px;height:25px;overflow:hidden;">
                                    <div style="width:72%;height:100%;background:#166548;color:white;text-align:right;padding-right:8px;font-weight:900;line-height:25px;">+8.5</div>
                                </div>

                                <div style="text-align:right;color:#334155;font-weight:800;">Cholesterol</div>
                                <div style="background:#e5e7eb;border-radius:7px;height:25px;overflow:hidden;">
                                    <div style="width:38%;height:100%;background:#eab948;color:#111827;text-align:right;padding-right:8px;font-weight:900;line-height:25px;">-4.2</div>
                                </div>

                                <div style="text-align:right;color:#334155;font-weight:800;">Glucose</div>
                                <div style="background:#e5e7eb;border-radius:7px;height:25px;overflow:hidden;">
                                    <div style="width:32%;height:100%;background:#a7d8b7;color:#111827;text-align:right;padding-right:8px;font-weight:900;line-height:25px;">-3.1</div>
                                </div>

                                <div style="text-align:right;color:#334155;font-weight:800;">Physically Active</div>
                                <div style="background:#e5e7eb;border-radius:7px;height:25px;overflow:hidden;">
                                    <div style="width:22%;height:100%;background:#f4c4c4;color:#111827;text-align:right;padding-right:8px;font-weight:900;line-height:25px;">+1.8</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </sheet>
    <footer>
        <button string="Close" special="cancel" class="btn-secondary"/>
    </footer>
</form>
        </field>
    </record>
    <!-- CVD_PREDICT_POPUP_FROM_HISTORY_END -->



    <!-- AI_CHOICE_POPUP_START -->
    <record id="view_med_patient_ai_choice_popup" model="ir.ui.view">
        <field name="priority">1100</field>
        <field name="name">med.patient.ai.choice.popup.form</field>
        <field name="model">med.patient</field>
        <field name="arch" type="xml">
            <form string="Predictive AI">
                <sheet>
                    <div style="background:#f8fafc;border:1px solid #d7dee8;border-radius:18px;padding:24px;box-shadow:0 12px 28px rgba(15,23,42,.06);">
                        <div style="margin-bottom:20px;">
                            <div style="font-size:1.35rem;font-weight:950;color:#0f172a;">Predictive AI Center</div>
                            <div style="font-size:.92rem;color:#64748b;margin-top:5px;">Choose the AI model to apply to this patient history.</div>
                        </div>

                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;">
                            <div style="background:white;border:1px solid #d7dee8;border-radius:16px;padding:20px;">
                                <div style="font-size:1.05rem;font-weight:950;color:#111827;margin-bottom:8px;">CVD Risk Prediction</div>
                                <div style="color:#64748b;line-height:1.35;margin-bottom:18px;">
                                    Estimates cardiovascular risk using clinical and lifestyle parameters.
                                </div>
                                <button name="action_open_cvd_prediction_popup"
                                        type="object"
                                        string="Open CVD Prediction"
                                        icon="fa-heartbeat"
                                        class="btn-primary"
                                        style="background:#6b5aa6;border-color:#6b5aa6;border-radius:8px;font-weight:850;"/>
                            </div>

                            <div style="background:white;border:1px solid #d7dee8;border-radius:16px;padding:20px;">
                                <div style="font-size:1.05rem;font-weight:950;color:#111827;margin-bottom:8px;">Heart Disease Prediction</div>
                                <div style="color:#64748b;line-height:1.35;margin-bottom:18px;">
                                    Detects heart disease signs using heart-specific clinical parameters.
                                </div>
                                <button name="action_open_heart_prediction_popup"
                                        type="object"
                                        string="Open Heart Disease Prediction"
                                        icon="fa-heart"
                                        class="btn-primary"
                                        style="background:#7c3aed;border-color:#7c3aed;border-radius:8px;font-weight:850;"/>
                            </div>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <!-- AI_CHOICE_POPUP_END -->

    <!-- HEART_DISEASE_POPUP_ONLY_START -->
    <record id="view_med_patient_heart_predict_popup" model="ir.ui.view">
        <field name="priority">1200</field>
        <field name="name">med.patient.heart.predict.popup.form</field>
        <field name="model">med.patient</field>
        <field name="arch" type="xml">
            <form string="Heart Disease AI Prediction">
                <sheet>
                    <div style="background:#f8fafc;border:1px solid #d7dee8;border-radius:18px;padding:22px 26px;box-shadow:0 12px 28px rgba(15,23,42,.06);">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px;">
                            <div>
                                <div style="font-size:1.25rem;font-weight:950;color:#0f172a;">Heart Disease AI Prediction</div>
                                <div style="font-size:.9rem;color:#64748b;margin-top:5px;">Random Forest heart disease clinical analysis</div>
                            </div>
                            <button name="action_compute_heart_disease"
                                    type="object"
                                    string="Compute Heart Disease"
                                    icon="fa-heart"
                                    class="btn-primary"
                                    style="background:#7c3aed;border-color:#7c3aed;border-radius:6px;font-weight:800;"/>
                        </div>

                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:30px;">
                            <div style="background:white;border:1px solid #d7dee8;border-radius:14px;overflow:hidden;">
                                <div style="background:#e5e7eb;padding:14px 20px;font-weight:950;color:#111827;">Clinical Heart Input Data</div>
                                <div style="display:grid;grid-template-columns:190px 1fr;gap:13px;padding:22px;align-items:center;">
                                    <div style="font-weight:850;">Chest Pain Type</div><div><field name="heart_cp" nolabel="1"/></div>
                                    <div style="font-weight:850;">Resting BP</div><div><field name="heart_trestbps" nolabel="1"/></div>
                                    <div style="font-weight:850;">Cholesterol</div><div><field name="heart_chol" nolabel="1"/></div>
                                    <div style="font-weight:850;">Fasting Blood Sugar</div><div><field name="heart_fbs" nolabel="1"/></div>
                                    <div style="font-weight:850;">Resting ECG</div><div><field name="heart_restecg" nolabel="1"/></div>
                                    <div style="font-weight:850;">Max Heart Rate</div><div><field name="heart_thalach" nolabel="1"/></div>
                                    <div style="font-weight:850;">Exercise Angina</div><div><field name="heart_exang" nolabel="1"/></div>
                                    <div style="font-weight:850;">Oldpeak</div><div><field name="heart_oldpeak" nolabel="1"/></div>
                                    <div style="font-weight:850;">Slope</div><div><field name="heart_slope" nolabel="1"/></div>
                                    <div style="font-weight:850;">Major Vessels</div><div><field name="heart_ca" nolabel="1"/></div>
                                    <div style="font-weight:850;">Thalassemia</div><div><field name="heart_thal" nolabel="1"/></div>
                                </div>
                            </div>

                            <div style="background:white;border:1px solid #d7dee8;border-radius:14px;overflow:hidden;">
                                <div style="background:#e5e7eb;padding:14px 20px;font-weight:950;color:#111827;">Prediction Result</div>
                                <div style="padding:24px;">
                                    <div style="display:grid;grid-template-columns:170px 1fr;gap:13px;">
                                        <div style="font-weight:900;color:#7f1d1d;">Heart Disease Risk</div>
                                        <div>
                                            <field name="heart_risk" nolabel="1" readonly="1" widget="badge"
                                                   decoration-success="heart_risk == 'not_detected'"
                                                   decoration-danger="heart_risk == 'detected'"/>
                                        </div>

                                        <div style="font-weight:900;color:#7f1d1d;">Heart Alert</div>
                                        <div><field name="heart_alert" nolabel="1" readonly="1" widget="boolean_toggle"/></div>

                                        <div style="font-weight:900;color:#7f1d1d;">Probability</div>
                                        <div><field name="heart_probability" nolabel="1" readonly="1"/></div>

                                        <div style="font-weight:900;color:#7f1d1d;">AI Message</div>
                                        <div><field name="heart_message" nolabel="1" readonly="1"/></div>

                                        <div style="font-weight:900;color:#7f1d1d;">Last checked</div>
                                        <div><field name="heart_last_checked" nolabel="1" readonly="1"/></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <!-- HEART_DISEASE_POPUP_ONLY_END -->

</odoo>













