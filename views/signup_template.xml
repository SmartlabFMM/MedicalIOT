<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="med_signup_page" name="MedIoT Signup Page">
        <t t-call="website.layout">
            <div class="med_auth_screen med_auth_signup_screen">
                <a href="/mediot" class="med_auth_home_btn">
                    <i class="fa fa-arrow-left"/> HOME
                </a>

                <div class="med_auth_bg_blur"></div>
                <div class="med_auth_overlay"></div>

                <div class="med_auth_container med_auth_signup_container">
                    <!-- LEFT PANEL -->
                    <div class="med_auth_left">
                        <div class="med_auth_brand">
                            <div class="med_signup_heart_match"><i class="fa fa-heart-o" title="Welcome"></i></div>
                        </div>

                        <h1 class="med_auth_title">WELCOME!</h1>
                        <p class="med_auth_subtitle">
                            Create your account to access the MedIoT platform
                        </p>

                        
                    </div>

                    <!-- DIVIDER -->
                    <div class="med_auth_divider"></div>

                    <!-- RIGHT PANEL -->
                    <div class="med_auth_right">
                        <div class="med_auth_form_card med_auth_signup_card">
                            <h2>Create Account</h2>
                            <p>Use your email for registration</p>

                            <t t-if="error">
                                <div class="alert alert-danger" role="alert">
                                    <t t-esc="error"/>
                                </div>
                            </t>

                            <t t-if="success">
                                <div class="alert alert-success" role="alert">
                                    <t t-esc="success"/>
                                </div>
                            </t>

                            <form action="/mediot/signup/submit" method="post" enctype="multipart/form-data" class="med_auth_form" autocomplete="off">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="med_auth_grid">
                                    <div class="med_auth_field">
                                        <input type="text" name="first_name" placeholder="First Name"
                                               t-att-value="form_data.get('first_name', '') if form_data else ''"/>
                                    </div>

                                    <div class="med_auth_field">
                                        <input type="text" name="last_name" placeholder="Last Name"
                                               t-att-value="form_data.get('last_name', '') if form_data else ''"/>
                                    </div>

                                    <div class="med_auth_field">
                                        <input type="email" name="login" placeholder="Email" autocomplete="new-email"
                                               t-att-value="form_data.get('email', '') if form_data else ''" required="required"/>
                                    </div>

                                    <div class="med_auth_field">
                                        <input type="text" name="phone" placeholder="Phone number" autocomplete="off"
                                               t-att-value="form_data.get('phone', '') if form_data else ''"/>
                                    </div>

                                    <div class="med_auth_field">
                                        <input type="text" name="city" placeholder="City"
                                               t-att-value="form_data.get('city', '') if form_data else ''"/>
                                    </div>

                                    <div class="med_auth_field">
                                        <input type="password" name="password" placeholder="Password" autocomplete="new-password" value="" required="required"/>
                                    </div>

                                    <div class="med_auth_field med_role_select_wrap">                                        <select id="med_signup_role" name="role">
                                            <option value="">Select role</option>
                                            <option value="doctor" t-att-selected="'selected' if form_data and form_data.get('role') == 'doctor' else None">Doctor</option>
                                            <option value="admin" t-att-selected="'selected' if form_data and form_data.get('role') == 'admin' else None">Admin</option>
                                        </select>
                                    </div>

                                    <div class="med_auth_field med_specialty_select_wrap">                                        <select id="med_signup_specialty" name="specialty">
                                            <option value="">Select specialty</option>
                                            <option value="general">General Medicine</option>
                                            <option value="cardiology">Cardiology</option>
                                            <option value="psychiatry">Psychiatry</option>
                                            <option value="neurology">Neurology</option>
                                            <option value="pediatrics">Pediatrics</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="med_auth_upload_box">
                                    <label>Verification Document</label>
                                    <input type="file" name="verification_file" accept=".pdf,.doc,.docx"/>
                                    <small>Accepted formats: PDF, DOC, DOCX</small>
                                </div>

                                <button type="submit" class="med_auth_submit_btn">
                                    Sign Up
                                </button>

                                <div class="med_auth_links">
                                    <a href="/mediot/login">Already have an account? Sign in</a>
                                    <span>·</span>
                                    <a href="/mediot">Back to home</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            
                <script>
                    document.addEventListener("DOMContentLoaded", function () {
                        const role = document.getElementById("med_signup_role");
                        const specialty = document.getElementById("med_signup_specialty");
                        const specialtyWrap = document.querySelector(".med_specialty_select_wrap");

                        function medSignupToggleSpecialty() {
                            if (!role || !specialty || !specialtyWrap) {
                                return;
                            }

                            if (role.value === "admin") {
                                specialty.value = "";
                                specialty.removeAttribute("required");
                                specialtyWrap.style.display = "none";
                            } else {
                                specialtyWrap.style.display = "";
                                if (role.value === "doctor") {
                                    specialty.setAttribute("required", "required");
                                } else {
                                    specialty.removeAttribute("required");
                                }
                            }
                        }

                        if (role) {
                            role.addEventListener("change", medSignupToggleSpecialty);
                            medSignupToggleSpecialty();
                        }
                    });
                </script>
            </div>
        </t>
    </template>
</odoo>

