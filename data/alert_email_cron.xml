<odoo>
    <record id="ir_cron_mediot_predictive_alert_email" model="ir.cron">
        <field name="name">MedIoT - Send Predictive Alert Emails</field>
        <field name="model_id" ref="model_med_alert"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_unconsulted_predictive_emails()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
