}

.med_login_role_left h1 {
    margin: 0 !important;
    font-size: 56px !important;
    font-weight: 300 !important;
    letter-spacing: 2px !important;
    color: white !important;
}

.med_login_role_left > p {
    margin: 12px 0 32px !important;
