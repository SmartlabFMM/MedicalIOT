/* =========================================================
   ROLE PAGE SAME BACKGROUND AS LOGIN
   ========================================================= */

.med_role_page {
    min-height: 100vh !important;
    position: relative !important;
    overflow: hidden !important;
    background: #0f2c52 !important;
}

/* blurred medical image */
.med_role_page::before {
    content: "" !important;
    position: fixed !important;
    inset: 0 !important;
    background:
        linear-gradient(135deg, rgba(18, 42, 78, 0.70), rgba(15, 47, 84, 0.72)),
        url("/med_iot_command_center/static/description/hero_new.jpg?v=2") center center / cover no-repeat !important;
    filter: blur(10px) saturate(110%) !important;
    transform: scale(1.08) !important;
    z-index: 0 !important;
}

/* dark blue overlay */
.med_role_page::after {
    content: "" !important;
    position: fixed !important;
    inset: 0 !important;
    background:
        radial-gradient(circle at 25% 20%, rgba(255,255,255,0.10), transparent 28%),
        linear-gradient(135deg, rgba(13, 38, 72, 0.64), rgba(13, 55, 91, 0.78)) !important;
    z-index: 1 !important;
    pointer-events: none !important;
}

/* keep content above background */
.med_role_page .med_role_home,
.med_role_page .med_role_center,
.med_role_page .med_role_head,
.med_role_page .med_role_cards {
    position: relative !important;
    z-index: 3 !important;
}

.med_role_page .med_role_center {
    min-height: 100vh !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 80px 24px !important;
}

/* white text like login */
.med_role_page .med_role_head h1 {
    color: #ffffff !important;
    text-shadow: 0 10px 30px rgba(0,0,0,0.22) !important;
}

.med_role_page .med_role_head p {
    color: rgba(255,255,255,0.82) !important;
}

/* role cards glass look */
.med_role_page .med_role_card {
    background: rgba(255,255,255,0.86) !important;
    border: 1px solid rgba(255,255,255,0.36) !important;
    box-shadow: 0 24px 60px rgba(10, 30, 60, 0.24) !important;
    backdrop-filter: blur(12px) !important;
    -webkit-backdrop-filter: blur(12px) !important;
}

.med_role_page .med_role_card h2 {
    color: #17243b !important;
}

.med_role_page .med_role_card p {
    color: #64748b !important;
}

/* home button always real home */
.med_role_page .med_role_home,
.med_role_home {
    background: linear-gradient(90deg, #58a8ff 0%, #5dd6c8 100%) !important;
    color: white !important;
}

/* ===== MAKE HEADER LOGO FILL THE WHOLE SQUARE ===== */
.med_nav_logo,
.navbar-brand .med_nav_logo,
.med_logo_box {
    width: 56px !important;
    height: 56px !important;
    padding: 0 !important;
    overflow: hidden !important;
    border-radius: 16px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
}

.med_nav_logo img,
.navbar-brand .med_nav_logo img,
.med_logo_box img,
.navbar-brand img {
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    max-height: none !important;
    object-fit: cover !important;   /* fills the whole square */
    display: block !important;
}

