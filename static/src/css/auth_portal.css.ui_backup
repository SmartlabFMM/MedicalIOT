    border: 1px solid rgba(255,255,255,0.18) !important;
    z-index: 2 !important;
}

/* keep MedIoT text perfectly placed */
header .navbar-brand span,
header .navbar-brand strong,
.o_header_standard .navbar-brand span,
.o_header_standard .navbar-brand strong,
nav .navbar-brand span,
