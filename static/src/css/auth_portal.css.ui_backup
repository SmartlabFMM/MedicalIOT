/* =========================================================
   DIRECT HEART LOGO FINAL
   ========================================================= */
.med_video_heart_logo {
    width: 58px !important;
    height: 58px !important;
    border-radius: 18px !important;
    background: linear-gradient(135deg, #53d0d4 0%, #5a90f6 100%) !important;
