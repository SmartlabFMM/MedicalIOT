}

.med_login_box .med_btn {
    height: 60px !important;
    border-radius: 999px !important;
    border: 0 !important;
    width: 100% !important;
    background: linear-gradient(90deg, #8db8ff 0%, #93e1d8 100%) !important;
    color: white !important;
    font-size: 17px !important;
    font-weight: 900 !important;
    box-shadow: 0 14px 28px rgba(70, 127, 224, 0.22) !important;
    cursor: pointer !important;
}

.med_login_box .med_btn:hover {
    transform: translateY(-1px) !important;
    box-shadow: 0 18px 34px rgba(70, 127, 224, 0.28) !important;
}

@media (max-width: 980px) {
    .med_login_role_shell {
        grid-template-columns: 1fr !important;
        padding: 90px 24px 40px !important;
