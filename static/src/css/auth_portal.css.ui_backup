/* =========================================================
   MedIoT Auth Portal CSS
   Restored file so Odoo frontend assets can compile
   ========================================================= */

:root {
    --med-main: #24395B;
    --med-main-2: #31466e;
    --med-main-dark: #1b2d49;
    --med-accent: #f28b58;
    --med-text: #16233a;
    --med-muted: #6c7890;
    --med-line: #e7edf6;
    --med-soft: #f6f9fc;
    --med-shadow: 0 18px 50px rgba(18, 30, 56, 0.14);
}

/* Hide default website header/footer on MedIoT auth pages */
.med_login_wrap ~ header,
.med_auth_page ~ header,
.med_video_page ~ header,
header#top,
footer#bottom,
.o_footer {
    display: none !important;
}

/* LOGIN */
.med_login_wrap {
    display: flex;
    min-height: 100vh;
    width: 100%;
    overflow: hidden;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.med_login_left {
    flex: 1;
    position: relative;
    overflow: hidden;
}

.med_login_left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.med_login_overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(16, 28, 54, 0.70), rgba(36, 57, 91, 0.24));
}

.med_top_badge {
    position: absolute;
    top: 36px;
    left: 48px;
    display: flex;
    align-items: center;
    gap: 12px;
    z-index: 2;
}

.med_badge_icon,
.med_panel_logo_icon {
    width: 42px;
    height: 42px;
    background: rgba(255, 255, 255, 0.16);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.med_badge_icon img,
.med_panel_logo_icon img {
    width: 26px;
    height: 26px;
    object-fit: contain;
}

.med_badge_name {
    font-size: 18px;
    font-weight: 700;
    color: white;
}

.med_badge_sub {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.72);
}

.med_hero {
    position: absolute;
    bottom: 60px;
    left: 48px;
    color: white;
    max-width: 450px;
    z-index: 2;
}

.med_hero h1 {
    font-size: 36px;
    font-weight: 800;
    margin: 0 0 12px;
    line-height: 1.15;
}

.med_hero p {
    font-size: 14px;
    color: rgba(255,255,255,.88);
    margin: 0;
    line-height: 1.6;
}

.med_login_right {
    width: 430px;
    flex-shrink: 0;
    background: white;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 52px 48px;
    box-sizing: border-box;
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.12);
}

.med_panel_logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 32px;
}

.med_panel_logo_icon {
    background: var(--med-main);
}

.med_panel_logo_icon img {
    filter: brightness(10);
}

.med_panel_logo_name {
    font-size: 18px;
    font-weight: 700;
    color: var(--med-text);
}

.med_login_title {
    font-size: 24px;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 4px;
}

.med_login_subtitle {
    font-size: 13px;
    color: var(--med-muted);
    margin-bottom: 28px;
}

.med_field {
    margin-bottom: 16px;
}

.med_field label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
}

.med_field input {
    width: 100%;
    box-sizing: border-box;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 14px;
    color: #0f172a;
    background: #f8fafc;
}

.med_btn,
.med_auth_submit_btn {
    width: 100%;
    background: linear-gradient(135deg, var(--med-main), var(--med-main-2)) !important;
    border: none;
    border-radius: 10px;
    padding: 13px;
    font-size: 15px;
    font-weight: 700;
    color: white;
    cursor: pointer;
    margin-top: 8px;
}

.med_err {
    background: #fee2e2;
    color: #b91c1c;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 13px;
    margin-bottom: 14px;
}

.med_links {
    margin-top: 20px;
    text-align: center;
    font-size: 12px;
    color: #94a3b8;
}

.med_links a {
    color: var(--med-main-2);
    text-decoration: none;
}

/* SIGNUP */
.med_auth_page {
    margin: 0;
    padding: 0;
    background: #f3f5fb;
    font-family: "Segoe UI", Tahoma, sans-serif;
    color: #1f2937;
    min-height: 100vh;
}

.med_auth_page * {
    box-sizing: border-box;
}

.med_auth_topbar {
    width: 100%;
    background: var(--med-main);
    height: 56px;
    display: flex;
    align-items: center;
}

.med_auth_topbar_inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.med_auth_brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #ffffff !important;
    text-decoration: none !important;
    font-size: 24px;
    font-weight: 700;
}

.med_auth_nav {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-left: auto;
    margin-right: 10px;
}

.med_auth_nav a {
    color: #ffffff !important;
    text-decoration: none !important;
    font-size: 13px;
    font-weight: 500;
}

.med_auth_nav_actions {
    display: flex;
    align-items: center;
    gap: 10px;
}

.med_auth_login_btn,
.med_auth_signup_btn {
    padding: 8px 18px;
    border-radius: 999px;
    text-decoration: none !important;
    font-size: 13px;
    font-weight: 600;
}

.med_auth_login_btn {
    color: #ffffff !important;
    border: 1px solid rgba(255,255,255,.55);
}

.med_auth_signup_btn {
    background: var(--med-accent);
    color: #ffffff !important;
}

.med_auth_center {
    min-height: calc(100vh - 56px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 28px 20px;
}

.med_auth_card {
    position: relative;
    width: 100%;
    max-width: 1160px;
    min-height: 720px;
    background: #ffffff;
    border-radius: 14px;
    box-shadow: 0 12px 35px rgba(17,24,39,.10);
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
}

.med_auth_floating_logo {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--med-main);
    color: #fff;
    padding: 10px 18px;
    border-radius: 8px;
    z-index: 5;
    font-weight: 700;
}

.med_auth_left_panel {
    background: var(--med-main);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 70px 50px 50px;
}

.med_auth_left_content {
    text-align: center;
    max-width: 340px;
    color: #ffffff;
}

.med_auth_left_content h2 {
    margin: 0 0 18px;
    font-size: 32px;
    font-weight: 700;
}

.med_auth_left_content p {
    margin: 0 0 28px;
    font-size: 17px;
    line-height: 1.6;
}

.med_auth_outline_btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 160px;
    height: 48px;
    border: 2px solid rgba(255,255,255,.75);
    border-radius: 999px;
    color: #ffffff !important;
    text-decoration: none !important;
    font-size: 18px;
    font-weight: 700;
}

.med_auth_right_panel {
    background: #ffffff;
    padding: 70px 36px 28px;
    display: flex;
    justify-content: center;
}

.med_auth_form_scroll {
    width: 100%;
    max-width: 360px;
    max-height: 620px;
    overflow-y: auto;
    padding-right: 10px;
}

.med_auth_form_header {
    text-align: center;
    margin-bottom: 20px;
}

.med_auth_form_header h3 {
    margin: 0 0 6px;
    font-size: 24px;
    font-weight: 700;
    color: #374151;
}

.med_auth_form_header p {
    margin: 0;
    font-size: 15px;
    color: #6b7280;
}

.med_auth_grid.two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 14px;
}

.med_auth_field {
    margin-bottom: 14px;
}

.med_auth_field input,
.med_auth_field select {
    width: 100%;
    height: 54px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 0 16px;
    background: #f7f8fb;
    font-size: 15px;
    color: #374151;
    outline: none;
}

.med_auth_upload {
    background: #fafbfc;
    border: 1px dashed #d8dee7;
    border-radius: 12px;
    padding: 16px;
    margin-top: 4px;
}

.med_auth_upload label {
    display: block;
    font-size: 14px;
    font-weight: 700;
    color: #374151;
    margin-bottom: 10px;
}

.med_auth_upload small {
    display: block;
    margin-top: 10px;
    color: #8b95a7;
    font-size: 13px;
}

@media (max-width: 1100px) {
    .med_auth_card {
        grid-template-columns: 1fr;
    }

    .med_auth_left_panel {
        min-height: 280px;
        padding-top: 90px;
    }
}

@media (max-width: 800px) {
    .med_login_wrap {
        flex-direction: column;
        position: relative;
    }

    .med_login_right {
        width: 100%;
    }

    .med_auth_nav {
        display: none;
    }

    .med_auth_grid.two {
        grid-template-columns: 1fr;
    }
}

/* =========================================================
   FORCE FIX LANDING PAGE /mediot
   ========================================================= */

html,
body {
    overflow-x: hidden !important;
}

.med_video_page {
    width: 100% !important;
    min-height: 100vh !important;
    background: #ffffff !important;
    color: #16233a !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
}

.med_video_hero {
    position: relative !important;
    min-height: 760px !important;
    overflow: hidden !important;
    padding-bottom: 150px !important;
}

.med_video_bg {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    z-index: 0 !important;
}

.med_video_overlay {
    position: absolute !important;
    inset: 0 !important;
    background: linear-gradient(
        90deg,
        rgba(24, 28, 33, 0.62) 0%,
        rgba(24, 28, 33, 0.25) 100%
    ) !important;
    z-index: 1 !important;
}

.med_video_nav {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    z-index: 20 !important;
    height: 70px !important;
    padding: 0 34px !important;
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    background: linear-gradient(90deg, #24395B 0%, #31466e 100%) !important;
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.12) !important;
}

.med_video_brand {
    display: flex !important;
    align-items: center !important;
    gap: 12px !important;
    color: white !important;
}

.med_video_brand_icon {
    width: 42px !important;
    height: 42px !important;
    border-radius: 12px !important;
    background: rgba(255, 255, 255, 0.12) !important;
    border: 1px solid rgba(255, 255, 255, 0.24) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
}

.med_video_brand_icon img {
    width: 25px !important;
    height: 25px !important;
    object-fit: contain !important;
    filter: brightness(10) !important;
}

.med_video_brand_text {
    font-size: 20px !important;
    font-weight: 800 !important;
    color: white !important;
}

.med_video_menu {
    display: flex !important;
    align-items: center !important;
    gap: 22px !important;
}

.med_video_menu a {
    color: white !important;
    text-decoration: none !important;
    font-size: 14px !important;
    font-weight: 600 !important;
}

.med_video_btn {
    min-width: 96px !important;
    height: 38px !important;
    padding: 0 18px !important;
    border-radius: 12px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-decoration: none !important;
    font-size: 13px !important;
    font-weight: 800 !important;
}

.med_video_btn.ghost {
    color: white !important;
    border: 1px solid rgba(255, 255, 255, 0.35) !important;
    background: rgba(255, 255, 255, 0.08) !important;
}

.med_video_btn.solid {
    color: white !important;
    background: #f28b58 !important;
    border: 1px solid #f28b58 !important;
}

.med_video_content {
    position: relative !important;
    z-index: 5 !important;
    max-width: 570px !important;
    padding: 150px 0 120px 120px !important;
    color: white !important;
}

.med_video_content h1 {
    margin: 0 !important;
    max-width: 540px !important;
    font-size: 54px !important;
    line-height: 1.02 !important;
    font-weight: 900 !important;
    letter-spacing: -1.2px !important;
    color: white !important;
}

.med_orange {
    color: #f28b58 !important;
}

.med_video_content p {
    margin-top: 20px !important;
    max-width: 500px !important;
    font-size: 16px !important;
    line-height: 1.7 !important;
    color: rgba(255, 255, 255, 0.90) !important;
}

.med_video_actions {
    display: flex !important;
    gap: 14px !important;
    margin-top: 28px !important;
}

.med_video_cta {
    min-width: 150px !important;
    height: 46px !important;
    border-radius: 13px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-decoration: none !important;
    font-size: 14px !important;
    font-weight: 800 !important;
}

.med_video_cta.primary {
    background: #f28b58 !important;
    color: white !important;
}

.med_video_cta.secondary {
    color: white !important;
    border: 1px solid rgba(255, 255, 255, 0.30) !important;
    background: rgba(255, 255, 255, 0.09) !important;
}

.med_video_stats {
    position: absolute !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    bottom: 55px !important;
    z-index: 8 !important;
    width: min(920px, calc(100% - 180px)) !important;
    background: rgba(255, 255, 255, 0.98) !important;
    border-radius: 22px !important;
    padding: 20px 18px !important;
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    box-shadow: 0 18px 50px rgba(18, 30, 56, 0.18) !important;
}

.med_video_stat {
    text-align: center !important;
}

.med_video_stat_num {
    font-size: 42px !important;
    line-height: 1 !important;
    font-weight: 900 !important;
    color: #31466e !important;
}

.med_video_stat_label {
    margin-top: 7px !important;
    font-size: 14px !important;
    color: #6d7788 !important;
}

.med_section {
    padding: 90px 24px !important;
}

.med_section_light {
    background: white !important;
}

.med_section_alt {
    background: #f6f9fc !important;
}

.med_section_intro {
    max-width: 860px !important;
    margin: 0 auto 50px !important;
    text-align: center !important;
}

.med_tag {
    display: inline-block !important;
    padding: 8px 16px !important;
    border-radius: 999px !important;
    background: #eef3fb !important;
    color: #31466e !important;
    font-size: 13px !important;
    font-weight: 800 !important;
    margin-bottom: 18px !important;
}

.med_section_intro h2 {
    margin: 0 0 14px !important;
    font-size: 40px !important;
    line-height: 1.1 !important;
    font-weight: 900 !important;
    color: #16233a !important;
}

.med_section_intro p {
    margin: 0 auto !important;
    max-width: 720px !important;
    font-size: 18px !important;
    line-height: 1.7 !important;
    color: #6c7890 !important;
}

.med_feature_grid,
.med_testimonial_grid {
    max-width: 1200px !important;
    margin: 0 auto !important;
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 28px !important;
}

.med_feature_card,
.med_testimonial_card {
    background: white !important;
    border: 1px solid #e7edf6 !important;
    border-radius: 24px !important;
    padding: 28px !important;
    box-shadow: 0 10px 30px rgba(20, 35, 61, 0.06) !important;
}

.med_feature_icon {
    width: 68px !important;
    height: 68px !important;
    border-radius: 999px !important;
    background: #f4f7fc !important;
    color: #31466e !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 28px !important;
    margin-bottom: 22px !important;
}

.med_feature_card h3 {
    margin: 0 0 12px !important;
    font-size: 26px !important;
    line-height: 1.15 !important;
    font-weight: 900 !important;
    color: #16233a !important;
}

.med_feature_card p,
.med_testimonial_card p {
    margin: 0 !important;
    font-size: 16px !important;
    line-height: 1.75 !important;
    color: #6c7890 !important;
}

.med_footer {
    background: linear-gradient(90deg, #16233a 0%, #2c4163 100%) !important;
    color: white !important;
    padding: 56px 28px 24px !important;
}

@media (max-width: 900px) {
    .med_video_content {
        padding: 130px 24px 240px !important;
        max-width: 100% !important;
    }

    .med_video_content h1 {
        font-size: 36px !important;
    }

    .med_video_stats {
        width: calc(100% - 28px) !important;
        grid-template-columns: 1fr !important;
        bottom: 20px !important;
    }

    .med_feature_grid,
    .med_testimonial_grid {
        grid-template-columns: 1fr !important;
    }

    .med_video_nav {
        height: auto !important;
        padding: 14px 18px !important;
        flex-direction: column !important;
        gap: 12px !important;
    }

    .med_video_menu {
        flex-wrap: wrap !important;
        justify-content: center !important;
    }
}

/* =========================================================
   FORCE LOGIN BUTTON VISIBLE
   ========================================================= */

.med_login_right form {
    width: 100% !important;
    display: block !important;
}

.med_login_right .med_btn,
.med_login_right button.med_btn,
button.med_btn {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    height: 56px !important;
    margin-top: 22px !important;
    margin-bottom: 18px !important;
    border: 0 !important;
    border-radius: 14px !important;
    background: linear-gradient(135deg, #24395B 0%, #31466e 100%) !important;
    color: #ffffff !important;
    font-size: 16px !important;
    font-weight: 900 !important;
    cursor: pointer !important;
    opacity: 1 !important;
    visibility: visible !important;
    box-shadow: 0 12px 24px rgba(36, 57, 91, 0.22) !important;
    text-align: center !important;
}

.med_login_right .med_btn:hover,
.med_login_right button.med_btn:hover {
    transform: translateY(-1px) !important;
    box-shadow: 0 16px 30px rgba(36, 57, 91, 0.28) !important;
}

.med_login_right .med_links {
    margin-top: 20px !important;
}

/* =========================================================
   FORCE LOGIN BUTTON VISIBLE
   ========================================================= */

.med_login_right form {
    width: 100% !important;
    display: block !important;
}

.med_login_right .med_btn,
.med_login_right button.med_btn,
button.med_btn {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    height: 56px !important;
    margin-top: 22px !important;
    margin-bottom: 18px !important;
    border: 0 !important;
    border-radius: 14px !important;
    background: linear-gradient(135deg, #24395B 0%, #31466e 100%) !important;
    color: #ffffff !important;
    font-size: 16px !important;
    font-weight: 900 !important;
    cursor: pointer !important;
    opacity: 1 !important;
    visibility: visible !important;
    box-shadow: 0 12px 24px rgba(36, 57, 91, 0.22) !important;
    text-align: center !important;
}

.med_login_right .med_btn:hover,
.med_login_right button.med_btn:hover {
    transform: translateY(-1px) !important;
    box-shadow: 0 16px 30px rgba(36, 57, 91, 0.28) !important;
}

.med_login_right .med_links {
    margin-top: 20px !important;
}

/* =========================================================
   ROLE SELECTION PAGE
   ========================================================= */

.med_role_page {
    min-height: 100vh !important;
    background: linear-gradient(135deg, #f7fbff 0%, #eef6ff 100%) !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    color: #16233a !important;
    position: relative !important;
    overflow: hidden !important;
}

.med_role_home {
    position: fixed !important;
    top: 18px !important;
    left: 22px !important;
    z-index: 10 !important;
    height: 34px !important;
    padding: 0 14px !important;
    border-radius: 999px !important;
    background: linear-gradient(135deg, #4f9df7 0%, #38c7d3 100%) !important;
    color: white !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
    text-decoration: none !important;
    font-size: 12px !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    box-shadow: 0 8px 20px rgba(59, 130, 246, 0.25) !important;
}

.med_role_center {
    min-height: 100vh !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 80px 24px !important;
}

.med_role_head {
    text-align: center !important;
    margin-bottom: 34px !important;
}

.med_role_head h1 {
    margin: 0 !important;
    color: #1f2937 !important;
    font-size: 34px !important;
    font-weight: 900 !important;
    letter-spacing: -0.5px !important;
}

.med_role_head p {
    margin: 10px 0 0 !important;
    color: #8a99ad !important;
    font-size: 15px !important;
}

.med_role_cards {
    display: grid !important;
    grid-template-columns: repeat(2, 260px) !important;
    gap: 42px !important;
    justify-content: center !important;
}

.med_role_card {
    height: 210px !important;
    border-radius: 18px !important;
    background: #ffffff !important;
    border: 1px solid #e6edf7 !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    text-align: center !important;
    text-decoration: none !important;
    color: #1f2937 !important;
    box-shadow: 0 18px 42px rgba(26, 43, 72, 0.10) !important;
    transition: all 0.22s ease !important;
}

.med_role_card:hover {
    transform: translateY(-6px) !important;
    box-shadow: 0 24px 54px rgba(26, 43, 72, 0.16) !important;
    text-decoration: none !important;
}

.med_role_card.admin {
    background: linear-gradient(180deg, #ecfff9 0%, #ffffff 100%) !important;
}

.med_role_card.doctor {
    background: linear-gradient(180deg, #eef4ff 0%, #ffffff 100%) !important;
}

.med_role_icon {
    width: 78px !important;
    height: 78px !important;
    border-radius: 999px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: white !important;
    font-size: 34px !important;
    margin-bottom: 24px !important;
    box-shadow: 0 12px 24px rgba(37, 99, 235, 0.22) !important;
}

.med_role_card.admin .med_role_icon {
    background: linear-gradient(135deg, #38c7a6 0%, #53d7bd 100%) !important;
}

.med_role_card.doctor .med_role_icon {
    background: linear-gradient(135deg, #477cf4 0%, #6698ff 100%) !important;
}

.med_role_card h2 {
    margin: 0 0 8px !important;
    color: #1f2937 !important;
    font-size: 19px !important;
    font-weight: 900 !important;
}

.med_role_card p {
    max-width: 200px !important;
    margin: 0 !important;
    color: #77869b !important;
    font-size: 12px !important;
    line-height: 1.45 !important;
}

@media (max-width: 700px) {
    .med_role_cards {
        grid-template-columns: 1fr !important;
        width: 100% !important;
        max-width: 320px !important;
        gap: 20px !important;
    }

    .med_role_card {
        width: 100% !important;
    }
}

/* =========================================================
   ROLE-BASED LOGIN PAGE
   ========================================================= */

.med_login_role_page {
    min-height: 100vh !important;
    background: linear-gradient(135deg, #f7fbff 0%, #eef6ff 100%) !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    color: #16233a !important;
    overflow: hidden !important;
}

.med_login_role_shell {
    min-height: 100vh !important;
