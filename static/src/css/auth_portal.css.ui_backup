    color: #17243b !important;
    font-size: 14px !important;
}

.med_video_page .med_newsletter_box button {
    border: 0 !important;
    border-radius: 999px !important;
    padding: 0 20px !important;
    background: #f28b58 !important;
    color: white !important;
