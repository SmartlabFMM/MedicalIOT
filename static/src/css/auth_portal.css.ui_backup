/* ===== brand block ===== */
.med_footer_logo {
    display: flex !important;
    align-items: center !important;
    gap: 12px !important;
    margin: 0 0 10px !important;
    flex-wrap: nowrap !important;
}

/* only the REAL icon bubble */
.med_footer_logo > span:first-child,
.med_footer_logo > div:first-child,
.med_footer_logo > i:first-child {
    width: 42px !important;
    height: 42px !important;
    min-width: 42px !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,0.16) !important;
    color: #ffffff !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 22px !important;
    font-weight: 800 !important;
    line-height: 1 !important;
    box-shadow: none !important;
}

/* reset other spans inside logo so text stops looking broken */
.med_footer_logo > span:not(:first-child),
.med_footer_logo > div:not(:first-child) {
    width: auto !important;
    height: auto !important;
    min-width: 0 !important;
    border-radius: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: block !important;
    color: #ffffff !important;
    font-size: 18px !important;
    font-weight: 800 !important;
    line-height: 1.1 !important;
}

.med_footer_logo strong,
.med_footer_logo b {
    color: #ffffff !important;
    font-size: 18px !important;
    font-weight: 800 !important;
    line-height: 1.1 !important;
    margin: 0 !important;
    white-space: nowrap !important;
}

.med_footer_logo + p {
    margin: 0 !important;
    max-width: 240px !important;
    color: rgba(255,255,255,0.9) !important;
}

/* services/contact tighter */
.med_footer ul,
.med_video_footer ul,
.mediot-footer-compact ul {
    padding: 0 !important;
    margin: 0 !important;
    list-style: none !important;
}

.med_footer li,
.med_video_footer li,
.mediot-footer-compact li {
    margin-bottom: 8px !important;
}

/* social icons */
.med_socials {
    display: flex !important;
    gap: 10px !important;
    margin: 4px 0 12px !important;
    flex-wrap: wrap !important;
}

.med_socials span,
.med_socials a,
.med_video_footer .med_socials span,
.med_video_footer .med_socials a {
    width: 34px !important;
    height: 34px !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,0.14) !important;
    color: #ffffff !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 12px !important;
    font-weight: 800 !important;
    text-decoration: none !important;
}

/* ===== newsletter card like reference ===== */
.med_newsletter {
    max-width: 360px !important;
    background: rgba(255,255,255,0.08) !important;
    border-radius: 18px !important;
    padding: 14px !important;
    box-shadow: none !important;
}

.med_newsletter p {
    display: block !important;
    margin: 0 0 12px !important;
    font-size: 12px !important;
    line-height: 1.5 !important;
    color: rgba(255,255,255,0.9) !important;
}

.med_newsletter_box {
    width: 100% !important;
    height: 42px !important;
    display: flex !important;
    align-items: center !important;
    gap: 0 !important;
    padding: 4px !important;
    border-radius: 999px !important;
    background: rgba(255,255,255,0.12) !important;
    overflow: hidden !important;
}

.med_newsletter_box input {
    flex: 1 1 auto !important;
    min-width: 0 !important;
    height: 100% !important;
    border: 0 !important;
    outline: none !important;
    background: #ffffff !important;
    color: #2F456D !important;
    border-radius: 999px !important;
    padding: 0 14px !important;
    font-size: 12px !important;
}

.med_newsletter_box input::placeholder {
    color: #7d86a3 !important;
    opacity: 1 !important;
}

.med_newsletter_box button {
    flex: 0 0 auto !important;
    height: 100% !important;
    border: 0 !important;
    border-radius: 999px !important;
    padding: 0 18px !important;
    margin-left: 6px !important;
    background: linear-gradient(135deg, #ff9a57 0%, #f57c3d 100%) !important;
    color: #ffffff !important;
    font-size: 12px !important;
    font-weight: 800 !important;
    white-space: nowrap !important;
}

/* bottom */
.med_footer_bottom {
    max-width: 1120px !important;
    margin: 14px auto 0 !important;
    padding-top: 8px !important;
    border-top: 1px solid rgba(255,255,255,0.16) !important;
    text-align: center !important;
    font-size: 11px !important;
}

.med_footer_bottom p,
.med_footer_bottom span,
.med_footer_bottom div {
    margin: 0 !important;
    color: rgba(255,255,255,0.9) !important;
}

/* responsive */
@media (max-width: 900px) {
    .med_footer_grid,
    .med_video_footer .med_footer_grid,
    .mediot-footer-compact .med_footer_grid {
        grid-template-columns: 1fr !important;
        gap: 18px !important;
    }

    .med_newsletter {
        max-width: 100% !important;
    }
}

/* FOOTER V2 FINAL CLEAN */
.mediot_footer_v2 {
    background: #2F456D !important;
    background-image: none !important;
    padding: 24px 0 10px !important;
    margin: 0 !important;
}

.mediot_footer_v2 .container {
    max-width: 1120px !important;
}

.mediot_footer_grid_v2 {
    display: grid !important;
    grid-template-columns: 1.15fr 0.9fr 0.95fr 1.2fr !important;
    gap: 34px !important;
    align-items: start !important;
}

.mediot_footer_col_v2 h4 {
    margin: 0 0 14px !important;
    font-size: 16px !important;
    font-weight: 800 !important;
    line-height: 1.2 !important;
    color: #ffffff !important;
}

.mediot_footer_col_v2 p,
.mediot_footer_col_v2 li,
.mediot_footer_col_v2 span {
    color: rgba(255,255,255,0.92) !important;
    font-size: 12px !important;
    line-height: 1.7 !important;
}

.mediot_footer_col_v2 ul {
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
}

.mediot_footer_col_v2 li {
    margin: 0 0 8px !important;
}

/* brand */
.mediot_footer_logo_v2 {
    display: flex !important;
    align-items: center !important;
    gap: 12px !important;
    margin-bottom: 10px !important;
}

.mediot_footer_logo_v2 span {
    width: 44px !important;
    height: 44px !important;
    min-width: 44px !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,0.14) !important;
    color: #ffffff !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 22px !important;
    font-weight: 800 !important;
    line-height: 1 !important;
}

.mediot_footer_logo_v2 strong {
    color: #ffffff !important;
    font-size: 18px !important;
    font-weight: 800 !important;
    line-height: 1 !important;
}

.mediot_footer_brand_v2 p {
    max-width: 235px !important;
    margin: 0 !important;
}

/* contact */
.mediot_footer_contact_v2 li {
    display: flex !important;
    align-items: flex-start !important;
    gap: 10px !important;
}

.mediot_footer_contact_v2 i {
    width: 16px !important;
    margin-top: 4px !important;
    color: #ff9a57 !important;
    text-align: center !important;
}

/* socials */
.mediot_footer_socials_v2 {
    display: flex !important;
    gap: 12px !important;
    margin: 0 0 16px !important;
    flex-wrap: wrap !important;
}

.mediot_footer_socials_v2 a {
    width: 38px !important;
    height: 38px !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,0.14) !important;
    color: #ffffff !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-decoration: none !important;
    transition: all 0.2s ease !important;
}

.mediot_footer_socials_v2 a:hover {
    transform: translateY(-2px) !important;
    background: rgba(255,255,255,0.22) !important;
}

.mediot_footer_socials_v2 i {
    font-size: 16px !important;
}

/* newsletter */
.mediot_footer_newsletter_v2 {
    background: rgba(255,255,255,0.08) !important;
    border-radius: 18px !important;
    padding: 14px !important;
}

.mediot_footer_newsletter_v2 p {
    margin: 0 0 12px !important;
    font-size: 12px !important;
    line-height: 1.6 !important;
}

.mediot_footer_newsletter_box_v2 {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    background: rgba(255,255,255,0.10) !important;
    border-radius: 999px !important;
    padding: 4px !important;
}

.mediot_footer_newsletter_box_v2 input {
    flex: 1 1 auto !important;
    min-width: 0 !important;
    height: 42px !important;
    border: 0 !important;
    outline: none !important;
    border-radius: 999px !important;
    background: #ffffff !important;
    color: #2F456D !important;
    padding: 0 16px !important;
    font-size: 12px !important;
}

.mediot_footer_newsletter_box_v2 input::placeholder {
    color: #7a86a3 !important;
    opacity: 1 !important;
}

.mediot_footer_newsletter_box_v2 button {
    height: 42px !important;
    border: 0 !important;
    border-radius: 999px !important;
    padding: 0 18px !important;
    background: linear-gradient(135deg, #ff9a57 0%, #f57c3d 100%) !important;
    color: #ffffff !important;
    font-size: 12px !important;
    font-weight: 800 !important;
    white-space: nowrap !important;
}

/* bottom */
.mediot_footer_bottom_v2 {
    margin-top: 16px !important;
    padding-top: 10px !important;
    border-top: 1px solid rgba(255,255,255,0.14) !important;
    text-align: center !important;
}

.mediot_footer_bottom_v2 p {
    margin: 0 !important;
    color: rgba(255,255,255,0.9) !important;
    font-size: 11px !important;
}

/* responsive */
@media (max-width: 900px) {
    .mediot_footer_grid_v2 {
        grid-template-columns: 1fr !important;
        gap: 20px !important;
    }

    .mediot_footer_brand_v2 p {
        max-width: none !important;
    }
}

/* FINAL RIGHT WHITE GAP FIX - NO LAYOUT CHANGE */
html,
body {
    width: 100% !important;
    max-width: 100% !important;
    overflow-x: hidden !important;
    margin: 0 !important;
    padding: 0 !important;
}

#wrapwrap,
.o_website_page,
.med_video_page,
.med_video_hero,
.med_video_nav,
.med_video_footer,
.mediot_footer_v2 {
    max-width: 100% !important;
    overflow-x: hidden !important;
}

.med_video_page {
    background: #0b203d !important;
}

/* FINAL RIGHT WHITE GAP FIX - NO LAYOUT CHANGE */
html,
body {
    width: 100% !important;
    max-width: 100% !important;
    overflow-x: hidden !important;
    margin: 0 !important;
