/* =========================================================
   EMERGENCY LANDING PAGE RESTORE
   ========================================================= */

html,
body {
    overflow-x: hidden !important;
}

.o_login_wrap {
    display: none !important;
}

header#top,
footer#bottom,
.o_footer {
    display: none !important;
}

#wrapwrap {
    padding: 0 !important;
    margin: 0 !important;
}

.med_video_page {
    width: 100% !important;
    min-height: 100vh !important;
    background: #ffffff !important;
    color: #16233a !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
}

.med_video_hero {
    position: relative !important;
    min-height: 760px !important;
    overflow: hidden !important;
    padding-bottom: 150px !important;
}

.med_video_bg {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    z-index: 0 !important;
}

.med_video_overlay {
    position: absolute !important;
    inset: 0 !important;
    background: linear-gradient(
        90deg,
        rgba(15, 32, 58, 0.76) 0%,
        rgba(20, 45, 78, 0.46) 100%
    ) !important;
    z-index: 1 !important;
}

.med_video_nav {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    z-index: 20 !important;
    height: 70px !important;
    padding: 0 34px !important;
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    background: linear-gradient(90deg, #24395B 0%, #31466e 100%) !important;
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.12) !important;
}

.med_video_brand {
    display: flex !important;
    align-items: center !important;
    gap: 12px !important;
    color: white !important;
}

.med_video_brand_icon {
    width: 42px !important;
    height: 42px !important;
    border-radius: 12px !important;
    background: rgba(255, 255, 255, 0.12) !important;
    border: 1px solid rgba(255, 255, 255, 0.24) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
}

.med_video_brand_icon img {
    width: 25px !important;
    height: 25px !important;
    object-fit: contain !important;
}

.med_video_brand_text {
    font-size: 20px !important;
    font-weight: 800 !important;
    color: white !important;
}

.med_video_menu {
    display: flex !important;
    align-items: center !important;
    gap: 22px !important;
}

.med_video_menu a {
    color: white !important;
    text-decoration: none !important;
    font-size: 14px !important;
    font-weight: 700 !important;
}

.med_video_btn {
    min-width: 96px !important;
    height: 38px !important;
    padding: 0 18px !important;
    border-radius: 12px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-decoration: none !important;
    font-size: 13px !important;
    font-weight: 800 !important;
}

.med_video_btn.ghost {
    color: white !important;
    border: 1px solid rgba(255, 255, 255, 0.35) !important;
    background: rgba(255, 255, 255, 0.08) !important;
}

.med_video_btn.solid {
    color: white !important;
    background: #f28b58 !important;
    border: 1px solid #f28b58 !important;
}

.med_video_content {
    position: relative !important;
    z-index: 5 !important;
    max-width: 650px !important;
    padding: 150px 0 120px 120px !important;
    color: white !important;
}

.med_video_content h1 {
    margin: 0 !important;
    max-width: 620px !important;
    font-size: 58px !important;
    line-height: 1.02 !important;
    font-weight: 900 !important;
    letter-spacing: -1.2px !important;
    color: white !important;
}

.med_orange {
    color: #f28b58 !important;
}

.med_video_content p {
    margin-top: 20px !important;
    max-width: 520px !important;
    font-size: 17px !important;
    line-height: 1.7 !important;
    color: rgba(255, 255, 255, 0.92) !important;
}

.med_video_actions {
    display: flex !important;
    gap: 14px !important;
    margin-top: 28px !important;
}

.med_video_cta {
    min-width: 150px !important;
    height: 46px !important;
    border-radius: 13px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-decoration: none !important;
    font-size: 14px !important;
    font-weight: 800 !important;
}

.med_video_cta.primary {
    background: #f28b58 !important;
    color: white !important;
}

.med_video_cta.secondary {
    color: white !important;
    border: 1px solid rgba(255, 255, 255, 0.30) !important;
    background: rgba(255, 255, 255, 0.09) !important;
}

.med_video_stats {
    position: absolute !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    bottom: 55px !important;
    z-index: 8 !important;
    width: min(920px, calc(100% - 180px)) !important;
    background: rgba(255, 255, 255, 0.98) !important;
    border-radius: 22px !important;
    padding: 20px 18px !important;
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    box-shadow: 0 18px 50px rgba(18, 30, 56, 0.18) !important;
}

.med_video_stat {
    text-align: center !important;
}

.med_video_stat_num {
    font-size: 42px !important;
    line-height: 1 !important;
    font-weight: 900 !important;
    color: #31466e !important;
}

.med_video_stat_label {
    margin-top: 7px !important;
    font-size: 14px !important;
    color: #6d7788 !important;
}

.med_section {
    padding: 90px 24px !important;
}

.med_section_light {
    background: white !important;
}

.med_section_alt {
    background: #f6f9fc !important;
}

.med_section_intro {
    max-width: 860px !important;
    margin: 0 auto 50px !important;
    text-align: center !important;
}

.med_tag {
    display: inline-block !important;
    padding: 8px 16px !important;
    border-radius: 999px !important;
    background: #eef3fb !important;
    color: #31466e !important;
    font-size: 13px !important;
    font-weight: 800 !important;
    margin-bottom: 18px !important;
}

.med_section_intro h2 {
    margin: 0 0 14px !important;
    font-size: 40px !important;
    line-height: 1.1 !important;
    font-weight: 900 !important;
    color: #16233a !important;
}

.med_section_intro p {
    margin: 0 auto !important;
    max-width: 720px !important;
    font-size: 18px !important;
    line-height: 1.7 !important;
    color: #6c7890 !important;
}

.med_feature_grid,
.med_testimonial_grid {
    max-width: 1200px !important;
    margin: 0 auto !important;
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 28px !important;
}

.med_feature_card,
.med_testimonial_card {
    background: white !important;
    border: 1px solid #e7edf6 !important;
    border-radius: 24px !important;
    padding: 28px !important;
    box-shadow: 0 10px 30px rgba(20, 35, 61, 0.06) !important;
}

.med_footer {
    background: linear-gradient(90deg, #16233a 0%, #2c4163 100%) !important;
    color: white !important;
    padding: 56px 28px 24px !important;
}

@media (max-width: 900px) {
    .med_video_content {
        padding: 130px 24px 240px !important;
        max-width: 100% !important;
    }

    .med_video_content h1 {
        font-size: 36px !important;
    }

    .med_video_stats {
        width: calc(100% - 28px) !important;
        grid-template-columns: 1fr !important;
        bottom: 20px !important;
    }

    .med_feature_grid,
    .med_testimonial_grid {
        grid-template-columns: 1fr !important;
    }

    .med_video_nav {
        height: auto !important;
        padding: 14px 18px !important;
        flex-direction: column !important;
        gap: 12px !important;
    }

    .med_video_menu {
        flex-wrap: wrap !important;
        justify-content: center !important;
    }
}

/* =========================
   MEDIOT AUTH SHARED STYLE
   ========================= */

.med_auth_screen{
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    background: #dfe6f1;
}

.med_auth_bg_blur{
    position: absolute;
    inset: 0;
    background:
        linear-gradient(rgba(20,34,64,.72), rgba(20,34,64,.72)),
        url('/med_iot_command_center/static/description/bg.jpg') center center / cover no-repeat;
    filter: blur(10px);
    transform: scale(1.06);
    z-index: 0;
}

.med_auth_overlay{
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(44,67,109,.55), rgba(85,108,150,.35));
    z-index: 1;
}

.med_auth_home_btn{
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    border-radius: 999px;
    text-decoration: none !important;
    font-weight: 700;
    color: #fff !important;
    background: linear-gradient(90deg, #50b8d9, #6dd4c4);
    box-shadow: 0 8px 24px rgba(0,0,0,.15);
    transition: transform .25s ease, box-shadow .25s ease;
}

.med_auth_home_btn:hover{
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(0,0,0,.22);
}

.med_auth_container{
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1400px;
    min-height: 760px;
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    align-items: center;
    gap: 48px;
    padding: 48px 56px;
    border-radius: 28px;
}

.med_auth_left{
    color: #ffffff;
    display: flex;
    flex-direction: column;
    justify-content: center;
    animation: medFadeLeft .7s ease;
}

.med_auth_right{
    display: flex;
    justify-content: center;
    animation: medFadeUp .8s ease;
}

.med_auth_divider{
    width: 1px;
    align-self: stretch;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,.45), transparent);
}

.med_auth_brand{
    margin-bottom: 26px;
}

.med_auth_logo{
    width: 180px;
    max-width: 100%;
    object-fit: contain;
    filter: drop-shadow(0 10px 25px rgba(0,0,0,.18));
}

.med_auth_title{
    font-size: 4rem;
    line-height: 1;
    margin: 0 0 14px;
    color: #ffffff;
    font-weight: 300;
    letter-spacing: 1px;
}

.med_auth_subtitle{
    font-size: 1.15rem;
    color: rgba(255,255,255,.92);
    margin-bottom: 34px;
    max-width: 520px;
}

.med_auth_role_card{
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 22px 24px;
    border-radius: 22px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.22);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 12px 30px rgba(0,0,0,.12);
    max-width: 520px;
}

.med_auth_role_icon{
    width: 74px;
    height: 74px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #4c87ff, #6fa7ff);
    color: #fff;
    font-size: 2rem;
    box-shadow: 0 10px 24px rgba(76,135,255,.35);
    flex-shrink: 0;
}

.med_auth_role_text{
    display: flex;
    flex-direction: column;
}

.med_auth_role_text strong{
    color: #ffffff;
    font-size: 1.55rem;
    margin-bottom: 4px;
}

.med_auth_role_text span{
    color: rgba(255,255,255,.92);
    font-size: 1rem;
    line-height: 1.45;
}

.med_auth_form_card{
    width: 100%;
    max-width: 560px;
    background: rgba(247,249,252,.96);
    border-radius: 28px;
    padding: 42px 40px;
    box-shadow: 0 18px 40px rgba(0,0,0,.18);
    border: 1px solid rgba(255,255,255,.55);
}

.med_auth_form_card h2{
    margin: 0;
    font-size: 3rem;
    color: #18345d;
    font-weight: 800;
}

.med_auth_form_card p{
    margin: 8px 0 28px;
    color: #7186a8;
    font-size: 1.1rem;
}

.med_auth_form{
    display: flex;
    flex-direction: column;
    gap: 18px;
}

.med_auth_grid{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

.med_auth_field{
    width: 100%;
}

.med_auth_field input,
.med_auth_field select{
    width: 100%;
    height: 62px;
    border-radius: 16px;
    border: 1px solid #c8d3e4;
    background: #eaf0f8;
    color: #1e2d49;
    padding: 0 18px;
    font-size: 1.05rem;
    transition: all .25s ease;
    outline: none;
}

.med_auth_field input:focus,
.med_auth_field select:focus{
    border-color: #556C96;
    background: #f3f7fc;
    box-shadow: 0 0 0 4px rgba(85,108,150,.14);
}

.med_auth_upload_box{
    margin-top: 4px;
    padding: 18px;
    border-radius: 18px;
    border: 1px dashed #c8d3e4;
    background: rgba(234,240,248,.55);
}

.med_auth_upload_box label{
    display: block;
    font-weight: 700;
    color: #556C96;
    margin-bottom: 10px;
    font-size: 1.05rem;
}

.med_auth_upload_box input[type="file"]{
    display: block;
    width: 100%;
    margin-bottom: 8px;
}

.med_auth_upload_box small{
    color: #7f8ea7;
    font-size: .95rem;
}

.med_auth_submit_btn{
    width: 100%;
    height: 64px;
    border: none;
    border-radius: 18px;
    color: #fff;
    font-size: 1.15rem;
    font-weight: 800;
    background: linear-gradient(90deg, #445d89, #556C96);
    box-shadow: 0 12px 26px rgba(85,108,150,.28);
    transition: transform .25s ease, box-shadow .25s ease, filter .25s ease;
}

.med_auth_submit_btn:hover{
    transform: translateY(-2px);
    box-shadow: 0 18px 30px rgba(85,108,150,.34);
    filter: brightness(1.03);
}

.med_auth_links{
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    font-size: .98rem;
    margin-top: 6px;
}

.med_auth_links a{
    color: #6f87ab !important;
    text-decoration: none !important;
}

.med_auth_links a:hover{
    color: #445d89 !important;
}

.alert{
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 8px;
}

/* animation */
@keyframes medFadeLeft{
    from{opacity:0; transform:translateX(-30px);}
    to{opacity:1; transform:translateX(0);}
}

@keyframes medFadeUp{
    from{opacity:0; transform:translateY(28px);}
    to{opacity:1; transform:translateY(0);}
}

@media (max-width: 1100px){
    .med_auth_container{
        grid-template-columns: 1fr;
        gap: 26px;
        padding: 32px 24px;
    }

    .med_auth_divider{
        display: none;
    }

    .med_auth_left,
    .med_auth_right{
        justify-content: center;
        text-align: center;
    }

    .med_auth_role_card{
        margin: 0 auto;
        text-align: left;
    }

    .med_auth_title{
        font-size: 3rem;
    }
}

@media (max-width: 768px){
    .med_auth_screen{
        padding: 22px 14px;
    }

    .med_auth_form_card{
        padding: 28px 22px;
    }

    .med_auth_form_card h2{
        font-size: 2.25rem;
    }

    .med_auth_grid{
        grid-template-columns: 1fr;
    }

    .med_auth_title{
        font-size: 2.4rem;
    }

    .med_auth_logo{
        width: 130px;
    }
}


/* =========================================================
   SIGNUP SCALE DOWN OVERRIDE
   ========================================================= */

.med_auth_signup_screen {
    padding: 24px 36px !important;
    align-items: center !important;
}

.med_auth_signup_container {
    max-width: 1180px !important;
    min-height: 620px !important;
    gap: 34px !important;
    padding: 28px 42px !important;
}

.med_auth_signup_screen .med_auth_left {
    padding-left: 20px !important;
}

.med_auth_signup_screen .med_auth_logo {
    width: 118px !important;
    max-height: 118px !important;
}

.med_auth_signup_screen .med_auth_brand {
    margin-bottom: 18px !important;
}

.med_auth_signup_screen .med_auth_title {
    font-size: 46px !important;
    line-height: 1 !important;
    letter-spacing: 1px !important;
    margin-bottom: 10px !important;
}

.med_auth_signup_screen .med_auth_subtitle {
    font-size: 16px !important;
    line-height: 1.45 !important;
    margin-bottom: 24px !important;
    max-width: 440px !important;
}

.med_auth_signup_screen .med_auth_role_card {
    max-width: 430px !important;
    padding: 16px 18px !important;
    border-radius: 18px !important;
    gap: 14px !important;
}

.med_auth_signup_screen .med_auth_role_icon {
    width: 54px !important;
    height: 54px !important;
    font-size: 22px !important;
}

.med_auth_signup_screen .med_auth_role_text strong {
    font-size: 20px !important;
}

.med_auth_signup_screen .med_auth_role_text span {
    font-size: 13px !important;
    line-height: 1.35 !important;
}

.med_auth_signup_screen .med_auth_form_card {
    max-width: 500px !important;
    padding: 30px 32px !important;
    border-radius: 24px !important;
}

.med_auth_signup_screen .med_auth_form_card h2 {
    font-size: 38px !important;
    line-height: 1.05 !important;
}

.med_auth_signup_screen .med_auth_form_card p {
    font-size: 15px !important;
    margin: 6px 0 22px !important;
}

.med_auth_signup_screen .med_auth_grid {
    gap: 13px !important;
}

.med_auth_signup_screen .med_auth_field input,
.med_auth_signup_screen .med_auth_field select {
    height: 50px !important;
    border-radius: 14px !important;
    font-size: 14px !important;
    padding: 0 15px !important;
}

.med_auth_signup_screen .med_auth_upload_box {
    padding: 13px 15px !important;
    border-radius: 15px !important;
}

.med_auth_signup_screen .med_auth_upload_box label {
    font-size: 14px !important;
    margin-bottom: 8px !important;
}

.med_auth_signup_screen .med_auth_upload_box input[type="file"] {
    font-size: 13px !important;
}

.med_auth_signup_screen .med_auth_upload_box small {
    font-size: 12px !important;
}

.med_auth_signup_screen .med_auth_submit_btn {
    height: 52px !important;
    border-radius: 15px !important;
    font-size: 15px !important;
}

.med_auth_signup_screen .med_auth_links {
    font-size: 13px !important;
    margin-top: 2px !important;
}

.med_auth_signup_screen .med_auth_home_btn {
    top: 18px !important;
    left: 18px !important;
    padding: 10px 15px !important;
    font-size: 13px !important;
}

@media (max-width: 1100px) {
    .med_auth_signup_container {
        max-width: 760px !important;
        min-height: auto !important;
        padding: 28px 24px !important;
    }

    .med_auth_signup_screen .med_auth_title {
        font-size: 38px !important;
    }
}


/* ===== MAKE HEADER LOGO FILL THE WHOLE SQUARE ===== */
.med_nav_logo,
.navbar-brand .med_nav_logo,
.med_logo_box {
    width: 56px !important;
    height: 56px !important;
    padding: 0 !important;
    overflow: hidden !important;
    border-radius: 16px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
}

.med_nav_logo img,
.navbar-brand .med_nav_logo img,
.med_logo_box img,
.navbar-brand img {
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    max-height: none !important;
    object-fit: cover !important;   /* fills the whole square */
    display: block !important;
}

/* =========================================================
   LANDING PAGE FINAL POLISH - MEDIOT THEME
   ========================================================= */

/* 1) Logo: make the image fill the square */
.med_video_page .med_video_brand_icon,
.med_video_nav .med_video_brand_icon,
.med_video_brand_icon {
    width: 56px !important;
    height: 56px !important;
    min-width: 56px !important;
    border-radius: 16px !important;
    padding: 0 !important;
    overflow: hidden !important;
    background: rgba(255,255,255,0.10) !important;
    border: 1px solid rgba(255,255,255,0.22) !important;
    box-shadow: 0 10px 24px rgba(18, 32, 58, 0.20) !important;
}

.med_video_page .med_video_brand_icon img,
.med_video_nav .med_video_brand_icon img,
.med_video_brand_icon img {
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    max-height: none !important;
    object-fit: contain !important;
    transform: scale(2.35) !important;
    transform-origin: center !important;
    filter: none !important;
}

/* 2) Navbar spacing after bigger logo */
.med_video_page .med_video_brand {
    gap: 14px !important;
}

.med_video_page .med_video_brand_text {
    font-size: 25px !important;
    font-weight: 900 !important;
}

/* 3) Move white stats card higher under Learn More */
.med_video_page .med_video_stats {
    bottom: 105px !important;
    width: min(900px, calc(100% - 260px)) !important;
    padding: 22px 24px !important;
    border-radius: 22px !important;
    box-shadow: 0 24px 60px rgba(19, 34, 61, 0.20) !important;
}

.med_video_page .med_video_stat_num {
    color: #2f456e !important;
    font-size: 46px !important;
}

.med_video_page .med_video_stat_label {
    color: #7b879a !important;
    font-size: 15px !important;
}

/* Add enough bottom room so the raised stats card does not collide */
.med_video_page .med_video_hero {
    padding-bottom: 230px !important;
}

/* 4) Services / testimonial cards like reference, but MedIoT palette */
.med_video_page .med_testimonial_grid {
    max-width: 1220px !important;
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 30px !important;
    align-items: stretch !important;
}

.med_video_page .med_testimonial_card {
    position: relative !important;
    overflow: hidden !important;
    min-height: 360px !important;
    padding: 110px 34px 34px !important;
    border-radius: 28px !important;
    background: #ffffff !important;
    border: 1px solid #e8edf6 !important;
    box-shadow: 0 18px 45px rgba(31, 48, 80, 0.08) !important;
    text-align: center !important;
    transition: transform .25s ease, box-shadow .25s ease !important;
}

.med_video_page .med_testimonial_card::before {
    content: "" !important;
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    height: 92px !important;
    background: linear-gradient(135deg, #556C96 0%, #637EA9 52%, #7FA0C7 100%) !important;
    z-index: 0 !important;
}

.med_video_page .med_testimonial_card:hover {
    transform: translateY(-8px) !important;
    box-shadow: 0 26px 60px rgba(31, 48, 80, 0.16) !important;
}

.med_video_page .med_avatar,
.med_video_page .med_testimonial_card .med_avatar,
.med_video_page .med_testimonial_card > div:first-child {
    position: absolute !important;
    top: 45px !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    z-index: 2 !important;
    width: 86px !important;
    height: 86px !important;
    border-radius: 999px !important;
    background: linear-gradient(135deg, #556C96 0%, #8DA1C3 100%) !important;
    color: white !important;
    border: 5px solid #ffffff !important;
    box-shadow: 0 14px 30px rgba(45, 62, 96, 0.24) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 17px !important;
    font-weight: 900 !important;
    margin: 0 !important;
}

.med_video_page .med_badge,
.med_video_page .med_testimonial_card .med_badge {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin: 0 auto 18px !important;
    padding: 8px 16px !important;
    border-radius: 999px !important;
    background: rgba(85, 108, 150, 0.10) !important;
    color: #556C96 !important;
    font-size: 13px !important;
    font-weight: 800 !important;
}

.med_video_page .med_testimonial_card p {
    color: #66758f !important;
    font-size: 16px !important;
    line-height: 1.72 !important;
    margin: 0 0 22px !important;
    min-height: 110px !important;
    text-align: left !important;
}

.med_video_page .med_testimonial_card h4 {
    margin: 0 !important;
    color: #17243b !important;
    font-size: 22px !important;
    font-weight: 900 !important;
    text-align: center !important;
}

.med_video_page .med_testimonial_card span {
    display: block !important;
    margin-top: 6px !important;
    color: #8a97ad !important;
    font-size: 15px !important;
    text-align: center !important;
}

.med_video_page .med_testimonial_card a {
    display: inline-block !important;
    margin-top: 18px !important;
    color: #556C96 !important;
    font-weight: 800 !important;
    text-decoration: none !important;
}

/* 5) Contact section like reference, but MedIoT theme */
.med_video_page .med_contact_wrap {
    max-width: 1220px !important;
    margin: 0 auto !important;
    display: grid !important;
    grid-template-columns: 0.9fr 1.1fr !important;
    gap: 34px !important;
    align-items: stretch !important;
}

.med_video_page .med_contact_quote,
.med_video_page .med_contact_form {
    background: #ffffff !important;
    border: 1px solid #e8edf6 !important;
    border-radius: 28px !important;
    padding: 36px !important;
    box-shadow: 0 18px 45px rgba(31, 48, 80, 0.08) !important;
}

.med_video_page .med_contact_quote h2,
.med_video_page .med_contact_form h2,
.med_video_page .med_contact_form h3 {
    color: #17243b !important;
    font-size: 30px !important;
    font-weight: 900 !important;
    margin: 0 0 24px !important;
}

.med_video_page .med_contact_quote p,
.med_video_page .med_contact_quote li {
    color: #66758f !important;
    font-size: 16px !important;
    line-height: 1.75 !important;
}

.med_video_page .med_contact_quote blockquote {
    margin-top: 28px !important;
    padding: 22px 24px !important;
    border-radius: 18px !important;
    border-left: 5px solid #556C96 !important;
    background: #f3f6fb !important;
    color: #55606f !important;
    font-style: italic !important;
}

.med_video_page .med_contact_form form {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 18px !important;
}

.med_video_page .med_contact_form .med_form_row {
    margin: 0 !important;
}

.med_video_page .med_contact_form .med_form_row:nth-child(3),
.med_video_page .med_contact_form .med_form_row:nth-child(5),
.med_video_page .med_contact_form textarea,
.med_video_page .med_contact_form button {
    grid-column: 1 / -1 !important;
}

.med_video_page .med_contact_form input,
.med_video_page .med_contact_form textarea {
    width: 100% !important;
    box-sizing: border-box !important;
    border: 1.5px solid #dce4f1 !important;
    background: #f8fafd !important;
    border-radius: 16px !important;
    padding: 16px 18px !important;
    font-size: 15px !important;
    color: #17243b !important;
    outline: none !important;
    transition: all .22s ease !important;
}

.med_video_page .med_contact_form textarea {
    min-height: 150px !important;
    resize: vertical !important;
}

.med_video_page .med_contact_form input:focus,
.med_video_page .med_contact_form textarea:focus {
    border-color: #556C96 !important;
    background: white !important;
    box-shadow: 0 0 0 4px rgba(85,108,150,0.12) !important;
}

.med_video_page .med_contact_form button {
    width: 100% !important;
    height: 56px !important;
    border: none !important;
    border-radius: 16px !important;
    background: linear-gradient(135deg, #556C96 0%, #3f557c 100%) !important;
    color: white !important;
    font-weight: 900 !important;
    font-size: 16px !important;
    box-shadow: 0 14px 30px rgba(85,108,150,0.25) !important;
    cursor: pointer !important;
}

/* 6) Footer like reference, but blue/orange MedIoT theme */
.med_video_page .med_footer {
    background: linear-gradient(135deg, #24395B 0%, #556C96 52%, #7FA0C7 100%) !important;
    color: white !important;
    padding: 72px 28px 28px !important;
}

.med_video_page .med_footer_grid {
    max-width: 1220px !important;
    margin: 0 auto !important;
    display: grid !important;
    grid-template-columns: 1.25fr 1fr 1.15fr 1.35fr !important;
    gap: 50px !important;
    align-items: start !important;
}

.med_video_page .med_footer h4,
.med_video_page .med_footer h3 {
    color: white !important;
    font-size: 20px !important;
    font-weight: 900 !important;
    margin: 0 0 20px !important;
}

.med_video_page .med_footer p,
.med_video_page .med_footer li,
.med_video_page .med_footer a {
    color: rgba(255,255,255,0.88) !important;
    font-size: 15px !important;
    line-height: 1.9 !important;
    text-decoration: none !important;
}

.med_video_page .med_footer ul {
    padding: 0 !important;
    margin: 0 !important;
    list-style: none !important;
}

.med_video_page .med_footer_logo {
    display: flex !important;
    align-items: center !important;
    gap: 12px !important;
    margin-bottom: 18px !important;
}

.med_video_page .med_footer_logo span {
    width: 46px !important;
    height: 46px !important;
    border-radius: 999px !important;
    background: rgba(255,255,255,0.18) !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: white !important;
    font-weight: 900 !important;
}

.med_video_page .med_socials {
    display: flex !important;
    gap: 12px !important;
    margin: 0 0 22px !important;
}

.med_video_page .med_socials span {
    width: 38px !important;
    height: 38px !important;
    border-radius: 999px !important;
    background: rgba(255,255,255,0.16) !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: white !important;
    font-size: 12px !important;
    font-weight: 800 !important;
}

.med_video_page .med_newsletter_box {
    display: flex !important;
    overflow: hidden !important;
    border-radius: 999px !important;
    background: rgba(255,255,255,0.20) !important;
