    overflow: hidden !important;
}

.med_video_heart_logo span {
    line-height: 1 !important;
    transform: translateY(-2px) !important;
}

/* =========================================================
   LANDING FEATURE CARDS JS INTERACTION
   ========================================================= */

.med_feature_card {
    position: relative !important;
    overflow: hidden !important;
    cursor: pointer !important;
    transform:
        perspective(900px)
        rotateX(var(--med-tilt-x, 0deg))
        rotateY(var(--med-tilt-y, 0deg))
        translateY(0)
        scale(1) !important;
    transition:
        transform .22s ease,
        box-shadow .22s ease,
        border-color .22s ease,
        background .22s ease !important;
    will-change: transform !important;
}

.med_feature_card::after {
    content: "" !important;
    position: absolute !important;
    left: 28px !important;
    right: 28px !important;
    bottom: 0 !important;
    height: 4px !important;
    border-radius: 999px 999px 0 0 !important;
    background: linear-gradient(90deg, #556C96 0%, #7FA0C7 100%) !important;
    transform: scaleX(0) !important;
    transform-origin: center !important;
    transition: transform .25s ease !important;
}

.med_feature_card:hover {
    border-color: rgba(85, 108, 150, 0.28) !important;
    box-shadow: 0 24px 55px rgba(31, 48, 80, 0.12) !important;
    transform:
        perspective(900px)
        rotateX(var(--med-tilt-x, 0deg))
        rotateY(var(--med-tilt-y, 0deg))
        translateY(-8px)
        scale(1.01) !important;
}

.med_feature_card:hover::after,
.med_feature_card.med_feature_active::after {
    transform: scaleX(1) !important;
}

.med_feature_card.med_feature_active {
    border-color: rgba(85, 108, 150, 0.45) !important;
    background: linear-gradient(180deg, #ffffff 0%, #f7faff 100%) !important;
    box-shadow: 0 30px 70px rgba(31, 48, 80, 0.16) !important;
    transform:
        perspective(900px)
        rotateX(0deg)
        rotateY(0deg)
        translateY(-12px)
        scale(1.025) !important;
}

.med_feature_card.med_feature_pop {
    animation: medFeaturePop .48s ease both !important;
}

.med_feature_card .med_feature_icon {
    transition: transform .22s ease, background .22s ease, color .22s ease !important;
}

.med_feature_card:hover .med_feature_icon,
.med_feature_card.med_feature_active .med_feature_icon {
    transform: translateY(-4px) scale(1.08) !important;
    background: rgba(85, 108, 150, 0.12) !important;
    color: #556C96 !important;
}

@keyframes medFeaturePop {
    0% {
        transform: translateY(-8px) scale(1.01);
    }

    45% {
        transform: translateY(-16px) scale(1.035);
    }

    100% {
        transform: translateY(-12px) scale(1.025);
    }
}

/* =========================================================
   TESTIMONIAL REAL PHOTOS
   ========================================================= */
.med_testimonial_card .med_avatar_photo,
.med_avatar.med_avatar_photo {
    overflow: hidden !important;
    padding: 0 !important;
    background: #ffffff !important;
}

.med_testimonial_card .med_avatar_photo img,
.med_avatar.med_avatar_photo img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block !important;
    border-radius: 999px !important;
}

/* =========================================================
   DIRECT WHY MEDIOT FINAL POLISH
   ========================================================= */

.mediot-why-polished-intro {
    position: relative !important;
}

.mediot-why-badge {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 12px 22px !important;
    border-radius: 999px !important;
    background: linear-gradient(135deg, rgba(85,108,150,0.12), rgba(137,217,214,0.20)) !important;
    color: #1f3560 !important;
    border: 1px solid rgba(85,108,150,0.12) !important;
    box-shadow: 0 10px 25px rgba(26,42,74,0.08) !important;
    font-weight: 900 !important;
    letter-spacing: .02em !important;
}

.mediot-why-title {
    position: relative !important;
    max-width: 980px !important;
    margin-left: auto !important;
    margin-right: auto !important;
    line-height: 1.05 !important;
    letter-spacing: -0.03em !important;
}

.mediot-why-title::after {
    content: "" !important;
    display: block !important;
    width: 112px !important;
    height: 5px !important;
    margin: 18px auto 0 !important;
    border-radius: 999px !important;
    background: linear-gradient(90deg, #556C96, #89D9D6) !important;
}

.mediot-why-subtitle {
    max-width: 860px !important;
    margin-left: auto !important;
    margin-right: auto !important;
    color: #6A7EA3 !important;
    line-height: 1.75 !important;
}

/* cards */
.med_feature_card.mediot-why-card {
    position: relative !important;
    overflow: hidden !important;
    cursor: pointer !important;
    border-radius: 30px !important;
    border: 1px solid rgba(85,108,150,0.12) !important;
    background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%) !important;
    box-shadow: 0 18px 45px rgba(31,48,86,0.08) !important;
    transition: transform .32s ease, box-shadow .32s ease, border-color .32s ease !important;
}

.med_feature_card.mediot-why-card::before {
    content: "" !important;
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    height: 5px !important;
    background: linear-gradient(90deg, #556C96, #89D9D6, #F2995A) !important;
    opacity: .95 !important;
}

.med_feature_card.mediot-why-card:hover,
.med_feature_card.mediot-why-card.med_feature_active,
.med_feature_card.mediot-why-card.is-active {
    transform: translateY(-10px) !important;
    box-shadow: 0 26px 60px rgba(31,48,86,0.15) !important;
    border-color: rgba(85,108,150,0.28) !important;
}

.med_feature_icon.mediot-why-icon-wrap {
    background: linear-gradient(135deg, rgba(85,108,150,0.08), rgba(137,217,214,0.18)) !important;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.85),
        0 12px 28px rgba(31,48,86,0.08) !important;
    transition: transform .32s ease, box-shadow .32s ease !important;
}

.med_feature_card.mediot-why-card:hover .mediot-why-icon-wrap,
.med_feature_card.mediot-why-card.med_feature_active .mediot-why-icon-wrap,
.med_feature_card.mediot-why-card.is-active .mediot-why-icon-wrap {
    transform: scale(1.08) rotate(-4deg) !important;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.95),
        0 16px 34px rgba(85,108,150,0.16) !important;
}

.med_feature_card.mediot-why-card h3 {
    color: #13264a !important;
    letter-spacing: -0.02em !important;
}

.med_feature_card.mediot-why-card p {
    color: #667A9C !important;
    line-height: 1.75 !important;
}

/* =========================================================
   DIRECT SERVICES / TESTIMONIAL FINAL POLISH + REAL PHOTOS
   ========================================================= */

.med_testimonial_grid {
    align-items: stretch !important;
}

/* same professional treatment as Why MedIoT, but adapted to service/testimonial cards */
.med_testimonial_card {
    position: relative !important;
    overflow: hidden !important;
    cursor: pointer !important;
    border-radius: 30px !important;
    border: 1px solid rgba(85,108,150,0.12) !important;
    background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%) !important;
    box-shadow: 0 18px 45px rgba(31,48,86,0.08) !important;
    transition: transform .32s ease, box-shadow .32s ease, border-color .32s ease !important;
}

/* top professional header */
.med_testimonial_card::before {
    content: "" !important;
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    height: 100px !important;
    background: linear-gradient(135deg, #556C96 0%, #7899BF 100%) !important;
    z-index: 0 !important;
}

/* thin accent line */
.med_testimonial_card::after {
    content: "" !important;
    position: absolute !important;
    top: 0 !important;
    left: 28px !important;
    right: 28px !important;
    height: 5px !important;
    border-radius: 999px !important;
    background: linear-gradient(90deg, #556C96, #89D9D6, #F2995A) !important;
    opacity: .95 !important;
    z-index: 2 !important;
}

.med_testimonial_card:hover,
.med_testimonial_card.med_feature_active,
.med_testimonial_card.is-active {
    transform: translateY(-10px) !important;
    box-shadow: 0 26px 60px rgba(31,48,86,0.15) !important;
    border-color: rgba(85,108,150,0.28) !important;
}

/* real photo avatar */
.med_testimonial_card .med_avatar.med_avatar_photo,
.med_avatar.med_avatar_photo {
    position: absolute !important;
    top: 46px !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    width: 104px !important;
    height: 104px !important;
    border-radius: 999px !important;
    overflow: hidden !important;
    padding: 0 !important;
    background: #ffffff !important;
    border: 6px solid #ffffff !important;
    box-shadow: 0 16px 34px rgba(31,48,86,0.20) !important;
    color: transparent !important;
    font-size: 0 !important;
    z-index: 5 !important;
}

.med_testimonial_card .med_avatar.med_avatar_photo img,
.med_avatar.med_avatar_photo img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center center !important;
    display: block !important;
    border-radius: 999px !important;
}

/* keep badge under avatar */
.med_testimonial_card .med_badge {
    position: relative !important;
    z-index: 3 !important;
    margin-top: 34px !important;
    background: rgba(85,108,150,0.10) !important;
    color: #556C96 !important;
    box-shadow: 0 10px 24px rgba(31,48,86,0.06) !important;
}

/* text polish */
.med_testimonial_card p {
    position: relative !important;
    z-index: 3 !important;
    color: #667A9C !important;
    line-height: 1.75 !important;
}

.med_testimonial_card h4 {
    position: relative !important;
    z-index: 3 !important;
    color: #13264a !important;
    letter-spacing: -0.02em !important;
}

.med_testimonial_card span {
    position: relative !important;
    z-index: 3 !important;
}

.med_testimonial_card a {
    position: relative !important;
    z-index: 3 !important;
    color: #556C96 !important;
    transition: color .2s ease, transform .2s ease !important;
}

.med_testimonial_card a:hover {
    color: #F2995A !important;
    transform: translateY(-1px) !important;
}

/* =========================================================
   FOOTER COMPACT PROFESSIONAL DESIGN
   Only affects footer with .mediot-footer-compact
   ========================================================= */

footer.mediot-footer-compact,
.mediot-footer-compact {
    padding: 54px 0 26px !important;
    min-height: auto !important;
    background: linear-gradient(135deg, #314A70 0%, #7899BF 100%) !important;
    color: #ffffff !important;
    overflow: hidden !important;
}

/* main footer container */
.mediot-footer-compact .container,
.mediot-footer-compact .med_footer_container,
.mediot-footer-compact .med_footer_inner,
.mediot-footer-compact > div {
    max-width: 1180px !important;
    margin-left: auto !important;
    margin-right: auto !important;
}

/* reduce grid height/spacing */
.mediot-footer-compact .med_footer_grid,
.mediot-footer-compact .footer-grid,
.mediot-footer-compact .row {
    display: grid !important;
    grid-template-columns: 1.15fr .9fr 1fr 1.25fr !important;
    gap: 54px !important;
    align-items: start !important;
    margin-bottom: 34px !important;
}

/* headings smaller */
.mediot-footer-compact h2,
.mediot-footer-compact h3,
.mediot-footer-compact h4 {
    color: #ffffff !important;
    font-size: 20px !important;
    line-height: 1.2 !important;
    font-weight: 900 !important;
    margin: 0 0 16px !important;
}

/* text smaller */
.mediot-footer-compact p,
.mediot-footer-compact li,
.mediot-footer-compact a,
.mediot-footer-compact span {
    font-size: 14.5px !important;
    line-height: 1.7 !important;
    color: rgba(255,255,255,0.92) !important;
}

.mediot-footer-compact ul {
    padding-left: 0 !important;
    margin: 0 !important;
    list-style: none !important;
}

.mediot-footer-compact li {
    margin-bottom: 8px !important;
}

/* logo area smaller */
.mediot-footer-compact .med_footer_brand,
.mediot-footer-compact .footer-brand {
    display: flex !important;
    align-items: center !important;
    gap: 12px !important;
    margin-bottom: 18px !important;
}

.mediot-footer-compact .med_footer_logo,
.mediot-footer-compact .footer-logo,
.mediot-footer-compact .brand-icon {
    width: 48px !important;
    height: 48px !important;
    min-width: 48px !important;
    border-radius: 999px !important;
    font-size: 18px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: rgba(255,255,255,0.14) !important;
}

/* social buttons smaller and cleaner */
.mediot-footer-compact .med_socials,
.mediot-footer-compact .socials,
.mediot-footer-compact .med_footer_socials {
    display: flex !important;
    gap: 12px !important;
    margin: 14px 0 20px !important;
}

.mediot-footer-compact .med_socials a,
.mediot-footer-compact .socials a,
.mediot-footer-compact .med_footer_socials a,
.mediot-footer-compact .med_social_icon {
    width: 40px !important;
    height: 40px !important;
    min-width: 40px !important;
    border-radius: 999px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: rgba(255,255,255,0.14) !important;
    font-size: 13px !important;
    font-weight: 900 !important;
    text-decoration: none !important;
}

/* newsletter smaller */
.mediot-footer-compact form,
.mediot-footer-compact .med_footer_subscribe,
.mediot-footer-compact .subscribe-form {
    max-width: 320px !important;
}

.mediot-footer-compact input[type="email"],
.mediot-footer-compact input[type="text"] {
    height: 42px !important;
    border-radius: 999px !important;
    border: none !important;
    padding: 0 18px !important;
    font-size: 14px !important;
}

.mediot-footer-compact button,
.mediot-footer-compact input[type="submit"] {
    height: 42px !important;
    border-radius: 999px !important;
    padding: 0 20px !important;
    font-size: 14px !important;
    font-weight: 900 !important;
    background: #ff8954 !important;
    color: #ffffff !important;
    border: none !important;
}

/* bottom line and copyright */
.mediot-footer-compact .med_footer_bottom,
.mediot-footer-compact .footer-bottom,
.mediot-footer-compact hr {
    margin-top: 30px !important;
    padding-top: 22px !important;
    border-top: 1px solid rgba(255,255,255,0.18) !important;
}

.mediot-footer-compact .med_footer_bottom,
.mediot-footer-compact .footer-bottom {
    text-align: center !important;
    font-size: 13.5px !important;
    color: rgba(255,255,255,0.88) !important;
}

/* fallback: if footer uses direct children only */
.mediot-footer-compact > div:not(.container) {
    padding-left: 34px !important;
    padding-right: 34px !important;
}

@media (max-width: 900px) {
    .mediot-footer-compact .med_footer_grid,
    .mediot-footer-compact .footer-grid,
    .mediot-footer-compact .row {
        grid-template-columns: 1fr 1fr !important;
        gap: 28px !important;
    }
}

@media (max-width: 600px) {
    footer.mediot-footer-compact,
    .mediot-footer-compact {
        padding: 38px 0 22px !important;
    }

    .mediot-footer-compact .med_footer_grid,
    .mediot-footer-compact .footer-grid,
    .mediot-footer-compact .row {
        grid-template-columns: 1fr !important;
    }
}

