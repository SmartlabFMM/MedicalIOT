        margin-left: auto !important;
        margin-right: auto !important;
    }
}

/* =========================================================
   FINAL BLURRED IMAGE LOGIN THEME OVERRIDE
   ========================================================= */

.med_login_role_page {
    min-height: 100vh !important;
    position: relative !important;
    overflow: hidden !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    background: #eaf2fb !important;
}

.med_login_role_page::before {
    content: "" !important;
    position: absolute !important;
    inset: 0 !important;
    background: url("/med_iot_command_center/static/description/hero_new.jpg") center center / cover no-repeat !important;
    filter: blur(10px) !important;
    transform: scale(1.08) !important;
    z-index: 0 !important;
}

.med_login_role_page::after {
    content: "" !important;
    position: absolute !important;
    inset: 0 !important;
    background: linear-gradient(135deg, rgba(14, 37, 74, 0.74) 0%, rgba(36, 93, 170, 0.46) 100%) !important;
    z-index: 1 !important;
}

.med_role_home,
.med_login_role_shell {
    position: relative !important;
    z-index: 2 !important;
}

.med_login_role_shell {
